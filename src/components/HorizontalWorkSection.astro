---
import WorkPanel from './WorkPanel.astro';
---

<!--
  Horizontal scroll section: a tall outer container creates scroll runway.
  The inner sticky wrapper stays on-screen and translates its content
  horizontally based on the user's vertical scroll progress through the outer container.
-->
<section id="work" class="relative z-10 bg-slate-900" aria-label="My Work — portfolio projects">
  <!-- Scroll runway — (panelCount-1) scroll units + 1 viewport = 400vh -->
  <div id="horizontal-scroll-outer" class="relative" style="height: 400vh;">
    <!-- Sticky viewport -->
    <div
      class="sticky top-15 h-[calc(100vh-60px)] overflow-hidden flex flex-col"
    >
      <!-- Section header (inside sticky frame, clears nav) -->
      <div
        class="sticky-header shrink-0 z-20 pt-4 pb-2 px-8 md:px-16 pointer-events-none"
      >
        <p class="font-script text-sm md:text-base text-slate-400 mb-1">
          What I've been working on
        </p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-white">
          My Work
        </h2>
      </div>
      <!-- Horizontal track -->
      <div
        id="horizontal-track"
        class="flex items-stretch flex-1 will-change-transform transition-none"
      >
        <!-- Panel 1: Data — Dashboards, KPIs, Analytics -->
        <WorkPanel
          category="Data &amp; Analytics"
          categoryColor="blue"
          title="Dashboards &amp; KPI Reporting"
          tags={['SQL & BigQuery', 'Google Looker Studio', 'Data Visualization', 'KPI Development']}
        >
          <Fragment slot="description">
            <p
              class="text-slate-300 text-base md:text-lg leading-relaxed mb-4"
            >
              Built 20+ dashboards used by over 1,000 people — from support
              leads to VPs — to track live experiments, surface KPIs, and turn
              complex data into clear, actionable views.
            </p>
            <p class="text-slate-400 text-sm leading-relaxed mb-6">
              The goal is always the same: make data accessible to people who
              need it, without requiring them to write a single query.
            </p>
          </Fragment>
          <div
            class="w-full h-full rounded-2xl bg-linear-to-br from-blue-900/50 to-slate-800/80 border border-slate-700/50 p-8 flex flex-col justify-between"
          >
            <div class="space-y-4 mb-6">
              <div class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full bg-blue-400"></div>
                <span class="text-slate-300 text-sm"
                  >Real-time experiment tracking dashboards</span
                >
              </div>
              <div class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full bg-blue-400"></div>
                <span class="text-slate-300 text-sm"
                  >Cross-team KPI visibility for leadership</span
                >
              </div>
              <div class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full bg-blue-400"></div>
                <span class="text-slate-300 text-sm"
                  >Ad hoc SQL &amp; BigQuery analysis</span
                >
              </div>
              <div class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full bg-blue-400"></div>
                <span class="text-slate-300 text-sm"
                  >Data simplified for non-technical stakeholders</span
                >
              </div>
            </div>
            <!-- Interactive chart -->
            <div class="kpi-chart-wrapper flex-1 flex flex-col min-h-[160px]">
              <div class="relative flex-1">
                <svg class="kpi-chart w-full h-full" viewBox="0 0 400 190" preserveAspectRatio="xMidYMid meet">
                  <defs></defs>

                  <!-- Grid lines -->
                  <line x1="10" y1="170" x2="390" y2="170" stroke="rgba(148,163,184,0.12)" stroke-width="1"/>
                  <line x1="10" y1="130" x2="390" y2="130" stroke="rgba(148,163,184,0.05)" stroke-width="1" stroke-dasharray="4,4"/>
                  <line x1="10" y1="90" x2="390" y2="90" stroke="rgba(148,163,184,0.05)" stroke-width="1" stroke-dasharray="4,4"/>
                  <line x1="10" y1="50" x2="390" y2="50" stroke="rgba(148,163,184,0.05)" stroke-width="1" stroke-dasharray="4,4"/>
                  <line x1="10" y1="10" x2="390" y2="10" stroke="rgba(148,163,184,0.05)" stroke-width="1" stroke-dasharray="4,4"/>

                  <!-- Y-axis ticks -->
                  <line x1="8" y1="170" x2="14" y2="170" stroke="rgba(148,163,184,0.2)" stroke-width="1"/>
                  <line x1="8" y1="130" x2="14" y2="130" stroke="rgba(148,163,184,0.15)" stroke-width="1"/>
                  <line x1="8" y1="90" x2="14" y2="90" stroke="rgba(148,163,184,0.15)" stroke-width="1"/>
                  <line x1="8" y1="50" x2="14" y2="50" stroke="rgba(148,163,184,0.15)" stroke-width="1"/>
                  <line x1="8" y1="10" x2="14" y2="10" stroke="rgba(148,163,184,0.15)" stroke-width="1"/>

                  <!-- X-axis ticks -->
                  <line x1="10" y1="170" x2="10" y2="175" stroke="rgba(148,163,184,0.2)" stroke-width="1"/>
                  <line x1="86" y1="170" x2="86" y2="175" stroke="rgba(148,163,184,0.15)" stroke-width="1"/>
                  <line x1="162" y1="170" x2="162" y2="175" stroke="rgba(148,163,184,0.15)" stroke-width="1"/>
                  <line x1="238" y1="170" x2="238" y2="175" stroke="rgba(148,163,184,0.15)" stroke-width="1"/>
                  <line x1="314" y1="170" x2="314" y2="175" stroke="rgba(148,163,184,0.15)" stroke-width="1"/>
                  <line x1="390" y1="170" x2="390" y2="175" stroke="rgba(148,163,184,0.2)" stroke-width="1"/>

                  <!-- Line 2 area + stroke (behind) -->
                  <path class="kpi-area-2" d="" fill="rgba(52,211,153,0.1)" opacity="0"/>
                  <path class="kpi-line-2" d="" fill="none" stroke="rgb(52,211,153)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" opacity="0.6"/>

                  <!-- Line 1 area + stroke (front) -->
                  <path class="kpi-area" d="" fill="rgba(96,165,250,0.1)" opacity="0"/>
                  <path class="kpi-line" d="" fill="none" stroke="rgb(96,165,250)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>

                  <!-- Hover dots -->
                  <circle class="kpi-hover-dot" cx="0" cy="0" r="5" fill="rgb(96,165,250)" stroke="rgb(15,23,42)" stroke-width="2.5" opacity="0"/>
                  <circle class="kpi-hover-dot-2" cx="0" cy="0" r="5" fill="rgb(52,211,153)" stroke="rgb(15,23,42)" stroke-width="2.5" opacity="0"/>

                  <!-- Vertical scrub line -->
                  <line class="kpi-scrub-line" x1="0" y1="10" x2="0" y2="170" stroke="rgba(96,165,250,0.25)" stroke-width="1" opacity="0"/>
                </svg>
                <!-- Tooltip -->
                <div class="kpi-tooltip absolute hidden pointer-events-none bg-slate-800/95 border border-blue-400/30 rounded-lg px-3 py-2 text-xs shadow-lg backdrop-blur-sm z-10" style="transform: translate(-50%, -100%); margin-top: -12px;">
                  <div class="flex items-center gap-1.5"><span class="inline-block w-2 h-2 rounded-full" style="background:rgb(96,165,250)"></span><span class="kpi-tooltip-val1 text-blue-400 font-bold"></span></div>
                  <div class="flex items-center gap-1.5 mt-0.5"><span class="inline-block w-2 h-2 rounded-full" style="background:rgb(52,211,153)"></span><span class="kpi-tooltip-val2 text-emerald-400 font-bold"></span></div>
                </div>
              </div>
            </div>
          </div>
        </WorkPanel>

        <!-- Panel 2: Automation — Tools, Workflows, Process -->
        <WorkPanel
          category="Automation &amp; Tooling"
          categoryColor="emerald"
          title="Workflow Automation &amp; Internal Tools"
          tags={['Google App Script', 'AppSheet', 'Process Optimization', 'Workflow Automation']}
        >
          <Fragment slot="description">
            <p
              class="text-slate-300 text-base md:text-lg leading-relaxed mb-4"
            >
              Built internal tools and automated workflows that removed
              bottlenecks and gave time back to teams. From one-click approval
              systems to scripts that turned 15-minute tasks into 20-second
              ones.
            </p>
            <p class="text-slate-400 text-sm leading-relaxed mb-6">
              Good automation starts with good process design — understand
              the workflow first, then build the tool that makes it effortless.
            </p>
          </Fragment>
          <div
            class="w-full h-full rounded-2xl bg-linear-to-br from-emerald-900/40 to-slate-800/80 border border-slate-700/50 p-8 flex flex-col justify-between"
          >
            <div class="space-y-4 mb-6">
              <div class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full bg-emerald-400"></div>
                <span class="text-slate-300 text-sm"
                  >One-click approval workflows saving 5+ hours/day</span
                >
              </div>
              <div class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full bg-emerald-400"></div>
                <span class="text-slate-300 text-sm"
                  >Internal tools cutting per-case time by 98%</span
                >
              </div>
              <div class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full bg-emerald-400"></div>
                <span class="text-slate-300 text-sm"
                  >Process mapping and documentation for scale</span
                >
              </div>
              <div class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full bg-emerald-400"></div>
                <span class="text-slate-300 text-sm"
                  >Support resources used by 1,500+ agents</span
                >
              </div>
            </div>
            <div class="flex items-center justify-center flex-1">
              <div class="text-center">
                <svg
                  class="w-16 h-16 text-emerald-500/50 mx-auto mb-3"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1"
                  viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z"
                  ></path><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"
                  ></path></svg
                >
                <p class="text-slate-500 text-sm">Examples coming soon</p>
              </div>
            </div>
          </div>
        </WorkPanel>

        <!-- Panel 3: Development — Spread The Funds + upcoming projects -->
        <WorkPanel
          category="App Development"
          categoryColor="purple"
          title="Building Real Products"
          tags={['Flutter', 'Firebase', 'Dart', 'Full-Stack', 'In Progress']}
        >
          <Fragment slot="description">
            <p
              class="text-slate-300 text-base md:text-lg leading-relaxed mb-4"
            >
              Spread The Funds is a mobile app currently in closed testing on
              the Google Play Store — built with Flutter and Firebase from the
              ground up. Designed to solve a real problem around group financial
              management.
            </p>
            <p class="text-slate-400 text-sm leading-relaxed mb-6">
              A second project is underway, focused on a different problem
              space. More details as it takes shape.
            </p>
          </Fragment>
          <div
            class="w-full h-full rounded-2xl bg-linear-to-br from-purple-900/40 to-slate-800/80 border border-slate-700/50 p-4 md:p-6 flex flex-col justify-between"
          >
            <div class="space-y-4 mb-6">
              <div class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full bg-purple-400"></div>
                <span class="text-slate-300 text-sm"
                  >Spread The Funds — closed testing on Play Store</span
                >
              </div>
              <div class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full bg-purple-400"></div>
                <span class="text-slate-300 text-sm"
                  >Flutter + Firebase full-stack architecture</span
                >
              </div>
              <div class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full bg-purple-400"></div>
                <span class="text-slate-300 text-sm"
                  >Product design, development, and testing</span
                >
              </div>
              <div class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full bg-purple-400"></div>
                <span class="text-slate-300 text-sm"
                  >Next project in early development</span
                >
              </div>
            </div>

            <!-- App showcase cards -->
            <div class="grid grid-cols-2 gap-4">
              <!-- Spread The Funds -->
              <a
                href="/spread-the-fund"
                class="group flex flex-col rounded-xl overflow-hidden border border-purple-400/20 hover:border-purple-400/50 transition-colors bg-purple-400/10"
              >
                <span class="block px-3 py-2 text-purple-300 text-xs font-semibold uppercase tracking-wider text-center">Spread The Funds</span>
                <img
                  src="/spread-the-funds.png"
                  alt="Spread The Funds — group financial management app"
                  class="w-full h-40 object-cover object-top group-hover:opacity-90 transition-opacity"
                  loading="lazy"
                />
              </a>
              <!-- Flowing (WIP) -->
              <div
                class="group flex flex-col rounded-xl overflow-hidden border border-purple-400/20 bg-purple-400/10"
              >
                <span class="block px-3 py-2 text-purple-300 text-xs font-semibold uppercase tracking-wider text-center">Flowing (WIP)</span>
                <img
                  src="/flowing-app.png"
                  alt="Flowing — upcoming project, work in progress"
                  class="w-full h-40 object-cover object-top"
                  loading="lazy"
                />
              </div>
            </div>
          </div>
        </WorkPanel>

        <!-- Panel 4: Digital Community — Discord, Marathon ARG -->
        <WorkPanel
          category="Community"
          categoryColor="amber"
          title="Digital Community Building"
          tags={['Discord', 'Community Management', '1,500+ Members', 'Web Development']}
        >
          <Fragment slot="description">
            <p
              class="text-slate-300 text-base md:text-lg leading-relaxed mb-4"
            >
              Created and managed a 1,500+ member Discord community from
              scratch — building engagement, moderating content, and fostering
              a space where people came together around shared interests.
            </p>
            <p class="text-slate-400 text-sm leading-relaxed mb-6">
              Originally supported by a companion website built on GitHub
              Pages, giving the community a public presence and resource hub.
              This has since been superseded by an official community website
              and wiki.
            </p>
          </Fragment>
          <div
            class="w-full h-full rounded-2xl bg-linear-to-br from-amber-900/30 to-slate-800/80 border border-slate-700/50 p-4 md:p-6 flex flex-col justify-between"
          >
            <div class="space-y-3 mb-6">
              <div class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full bg-amber-400"></div>
                <span class="text-slate-300 text-sm"
                  >Built a 1,500+ member Discord server</span
                >
              </div>
              <div class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full bg-amber-400"></div>
                <span class="text-slate-300 text-sm"
                  >Community engagement and moderation</span
                >
              </div>
              <div class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full bg-amber-400"></div>
                <span class="text-slate-300 text-sm"
                  >Live community dashboard and data tracking</span
                >
              </div>
              <div class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full bg-amber-400"></div>
                <span class="text-slate-300 text-sm"
                  >Organic growth through shared interests</span
                >
              </div>
            </div>

            <!-- Community showcase cards -->
            <div class="grid grid-cols-3 gap-4 mb-4">
              <!-- Marathon ARG -->
              <a
                href="https://crowdtypical.github.io/Marathon-arg/dashboard.html"
                target="_blank"
                rel="noopener noreferrer"
                class="group flex flex-col rounded-xl overflow-hidden border border-amber-400/20 hover:border-amber-400/50 transition-colors bg-amber-400/10"
              >
                <span class="block px-3 py-2 text-amber-300 text-xs font-semibold uppercase tracking-wider text-center">Marathon ARG</span>
                <img
                  src="/marathon-arg-dashboard.png"
                  alt="CryoArchive Dashboard — live tracking for the Marathon ARG community project"
                  class="w-full h-32 object-cover object-top group-hover:opacity-90 transition-opacity"
                  loading="lazy"
                />
              </a>
              <!-- Breacher.net -->
              <a
                href="https://breacher.net"
                target="_blank"
                rel="noopener noreferrer"
                class="group flex flex-col rounded-xl overflow-hidden border border-amber-400/20 hover:border-amber-400/50 transition-colors bg-amber-400/10"
              >
                <span class="block px-3 py-2 text-amber-300 text-xs font-semibold uppercase tracking-wider text-center">Breacher.net</span>
                <img
                  src="/breacher-net.png"
                  alt="Breacher.net — official community website"
                  class="w-full h-32 object-cover object-top group-hover:opacity-90 transition-opacity"
                  loading="lazy"
                />
              </a>
              <!-- Community Wiki -->
              <a
                href="https://wiki.breacher.net"
                target="_blank"
                rel="noopener noreferrer"
                class="group flex flex-col rounded-xl overflow-hidden border border-amber-400/20 hover:border-amber-400/50 transition-colors bg-amber-400/10"
              >
                <span class="block px-3 py-2 text-amber-300 text-xs font-semibold uppercase tracking-wider text-center">Breacher Wiki</span>
                <img
                  src="/community-wiki.png"
                  alt="Community Wiki — collaborative knowledge base"
                  class="w-full h-32 object-cover object-top group-hover:opacity-90 transition-opacity"
                  loading="lazy"
                />
              </a>
            </div>

            <!-- Discord live indicator -->
            <div class="flex items-center justify-center">
              <div
                class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-amber-400/10 text-amber-300 text-sm font-medium"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03ZM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.956 2.418-2.157 2.418Zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.946 2.418-2.157 2.418Z"></path></svg>
                <span class="relative flex h-2.5 w-2.5">
                  <span class="discord-ping absolute inline-flex h-full w-full animate-ping rounded-full bg-green-400 opacity-75"></span>
                  <span class="discord-dot relative inline-flex h-2.5 w-2.5 rounded-full bg-green-500"></span>
                </span>
                <span class="discord-count text-sm">Loading...</span>
              </div>
            </div>
          </div>
        </WorkPanel>
      </div>
    </div>
  </div>

  <!-- Horizontal scroll progress indicator (draggable) -->
  <div
    id="scroll-progress-wrapper"
    class="sticky bottom-0 left-0 right-0 z-20 pb-6 px-4 select-none opacity-0 translate-y-full transition-all duration-500 ease-out pointer-events-none"
    style="position: sticky;"
  >
    <div
      id="scroll-progress-bar"
      class="relative cursor-pointer py-3"
      style="touch-action: none;"
    >
      <div class="flex gap-1.5 h-3">
        <!-- Segment tracks (1 per panel transition) -->
        <div class="segment-track flex-1 bg-slate-800 rounded-full relative">
          <div
            class="segment-fill relative h-full bg-linear-to-r from-blue-500 to-blue-400 rounded-full overflow-hidden"
            data-segment="0"
          >
          </div>
        </div>
        <div class="segment-track flex-1 bg-slate-800 rounded-full relative">
          <div
            class="segment-fill relative h-full bg-linear-to-r from-blue-400 to-purple-400 rounded-full overflow-hidden"
            data-segment="1"
          >
          </div>
        </div>
        <div class="segment-track flex-1 bg-slate-800 rounded-full relative">
          <div
            class="segment-fill relative h-full bg-linear-to-r from-purple-400 to-fuchsia-500 rounded-full overflow-hidden"
            data-segment="2"
          >
          </div>
        </div>
      </div>
      <!-- Drag handle -->
      <div
        id="scroll-handle"
        class="absolute top-1/2 -translate-y-1/2 w-5 h-5 rounded-full shadow-lg pointer-events-none transition-none scroll-handle"
        style="left: 0%;"
      >
      </div>
    </div>
  </div>
</section>

<style>
  .segment-fill {
    transition: background-image 400ms ease;
  }

  .segment-complete {
    background-image: linear-gradient(
      to right,
      #065f46,
      #10b981,
      #6ee7b7
    ) !important;
  }

  .segment-track-complete::after {
    content: '✓';
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%) scale(0);
    font-size: 32px;
    font-weight: 300;
    line-height: 1;
    color: rgba(255, 255, 255, 0.9);
    font-family: system-ui, sans-serif;
    -webkit-text-stroke: 2px rgba(255, 255, 255, 0.9);
