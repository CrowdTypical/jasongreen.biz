<script is:inline>
  (function () {
    var countEls = document.querySelectorAll('.discord-count');
    var dotEls = document.querySelectorAll('.discord-dot');
    var pingEls = document.querySelectorAll('.discord-ping');
    if (!countEls.length) return;

    fetch('https://discord.com/api/guilds/1480378420343869534/widget.json')
      .then(function (res) {
        if (!res.ok) throw new Error('HTTP ' + res.status);
        return res.json();
      })
      .then(function (data) {
        var online = data.presence_count || 0;
        countEls.forEach(function (el) {
          el.textContent = online.toLocaleString() + ' online';
        });
      })
      .catch(function () {
        countEls.forEach(function (el) { el.textContent = 'Offline'; });
        dotEls.forEach(function (el) {
          el.className = el.className.replace('bg-green-500', 'bg-slate-500');
        });
        pingEls.forEach(function (el) {
          el.className = el.className.replace('bg-green-400', 'bg-slate-400');
        });
      });
  })();
</script>

<script is:inline>
  (function () {
    // Two independent datasets, both starting low and trending up
    var RAW1 = [0, 12, 20, 18, 35, 42, 55, 50, 68, 80];
    var RAW2 = [0, 8, 15, 0, 10, 15, 36, 67, 22, 0];

    function buildPoints(data) {
      var min = Math.min.apply(null, data);
      var max = Math.max.apply(null, data);
      var range = max - min || 1;
      var pts = [];
      for (var i = 0; i < data.length; i++) {
        var x = 10 + (380 / (data.length - 1)) * i;
        var y = 170 - ((data[i] - min) / range) * 155;
        pts.push({ x: x, y: y, val: data[i] });
      }
      return pts;
    }

    function smoothPath(pts) {
      if (pts.length < 2) return '';
      // Monotone cubic spline — prevents overshooting between points
      var n = pts.length;
      var dx = [], dy = [], m = [], a = [];
      for (var i = 0; i < n - 1; i++) {
        dx[i] = pts[i + 1].x - pts[i].x;
        dy[i] = (pts[i + 1].y - pts[i].y) / dx[i];
      }
      m[0] = dy[0];
      m[n - 1] = dy[n - 2];
      for (var i = 1; i < n - 1; i++) {
        if (dy[i - 1] * dy[i] <= 0) {
          m[i] = 0;
        } else {
          m[i] = (dy[i - 1] + dy[i]) / 2;
        }
      }
      // Fritsch-Carlson: clamp tangents to prevent overshoot
      for (var i = 0; i < n - 1; i++) {
        if (Math.abs(dy[i]) < 1e-6) {
          m[i] = 0;
          m[i + 1] = 0;
        } else {
          a = m[i] / dy[i];
          var b = m[i + 1] / dy[i];
          var s = a * a + b * b;
          if (s > 9) {
            var t = 3 / Math.sqrt(s);
            m[i] = t * a * dy[i];
            m[i + 1] = t * b * dy[i];
          }
        }
      }
      var d = 'M' + pts[0].x + ',' + pts[0].y;
      for (var i = 0; i < n - 1; i++) {
        var third = dx[i] / 3;
        var cp1x = pts[i].x + third;
        var cp1y = pts[i].y + m[i] * third;
        var cp2x = pts[i + 1].x - third;
        var cp2y = pts[i + 1].y - m[i + 1] * third;
        d += ' C' + cp1x + ',' + cp1y + ' ' + cp2x + ',' + cp2y + ' ' + pts[i + 1].x + ',' + pts[i + 1].y;
      }
      return d;
    }

    function renderLine(lineEl, areaEl, pts) {
      var lineD = smoothPath(pts);
      lineEl.setAttribute('d', lineD);
      areaEl.setAttribute('d', lineD + ' L' + pts[pts.length - 1].x + ',170 L' + pts[0].x + ',170 Z');
    }

    document.querySelectorAll('.kpi-chart').forEach(function (svg) {
      var wrapper = svg.closest('.kpi-chart-wrapper');
      if (!wrapper) return;

      var line1 = svg.querySelector('.kpi-line');
      var area1 = svg.querySelector('.kpi-area');
      var line2 = svg.querySelector('.kpi-line-2');
      var area2 = svg.querySelector('.kpi-area-2');
      var dot = svg.querySelector('.kpi-hover-dot');
      var scrubLine = svg.querySelector('.kpi-scrub-line');
      var dot2 = svg.querySelector('.kpi-hover-dot-2');
      var tooltip = wrapper.querySelector('.kpi-tooltip');
      var tooltipVal1 = tooltip.querySelector('.kpi-tooltip-val1');
      var tooltipVal2 = tooltip.querySelector('.kpi-tooltip-val2');

      var pts1 = buildPoints(RAW1);
      var pts2 = buildPoints(RAW2);
      renderLine(line1, area1, pts1);
      renderLine(line2, area2, pts2);

      // Create unique gradient IDs for this SVG instance
      var uid = Math.random().toString(36).substr(2, 6);
      var defs = svg.querySelector('defs');
      var NS = 'http://www.w3.org/2000/svg';

      function makeGradient(id, color, topOpacity) {
        var g = document.createElementNS(NS, 'linearGradient');
        g.setAttribute('id', id);
        g.setAttribute('x1', '0'); g.setAttribute('y1', '0');
        g.setAttribute('x2', '0'); g.setAttribute('y2', '1');
        var s1 = document.createElementNS(NS, 'stop');
        s1.setAttribute('offset', '0%');
        s1.setAttribute('stop-color', color);
        s1.setAttribute('stop-opacity', topOpacity);
        var s2 = document.createElementNS(NS, 'stop');
        s2.setAttribute('offset', '100%');
        s2.setAttribute('stop-color', color);
        s2.setAttribute('stop-opacity', '0.02');
        g.appendChild(s1); g.appendChild(s2);
        defs.appendChild(g);
        return id;
      }

      var gid1 = makeGradient('kpi-g1-' + uid, 'rgb(96,165,250)', '0.35');
      var gid2 = makeGradient('kpi-g2-' + uid, 'rgb(52,211,153)', '0.25');
      area1.setAttribute('fill', 'url(#' + gid1 + ')');
      area2.setAttribute('fill', 'url(#' + gid2 + ')');

      // Animate both lines on scroll
      [line1, line2].forEach(function (ln) {
        var len = ln.getTotalLength();
        ln.style.strokeDasharray = len;
        ln.style.strokeDashoffset = len;
        ln.style.transition = 'none';
      });

      var animated = false;
      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting && !animated) {
            animated = true;
            [line1, line2].forEach(function (ln) {
              ln.style.transition = 'stroke-dashoffset 1.8s cubic-bezier(0.4, 0, 0.2, 1)';
              ln.style.strokeDashoffset = '0';
            });
            [area1, area2].forEach(function (a) {
              a.style.transition = 'opacity 1s ease 0.8s';
              a.style.opacity = '1';
            });
            observer.disconnect();
          }
        });
      }, { threshold: 0.3 });
      observer.observe(svg);

      // Hover — snap to nearest point on both lines
      var chartContainer = svg.parentElement;
      chartContainer.addEventListener('mousemove', function (e) {
        var rect = svg.getBoundingClientRect();
        var svgX = ((e.clientX - rect.left) / rect.width) * 400;

        // Find nearest index by x position
        var idx = 0;
        var minDist = Math.abs(svgX - pts1[0].x);
        for (var i = 1; i < pts1.length; i++) {
          var dist = Math.abs(svgX - pts1[i].x);
          if (dist < minDist) { minDist = dist; idx = i; }
        }

        var c1 = pts1[idx];
        var c2 = pts2[idx];

        dot.setAttribute('cx', c1.x);
        dot.setAttribute('cy', c1.y);
        dot.style.opacity = '1';
        dot2.setAttribute('cx', c2.x);
        dot2.setAttribute('cy', c2.y);
        dot2.style.opacity = '1';
        scrubLine.setAttribute('x1', c1.x);
        scrubLine.setAttribute('x2', c1.x);
        scrubLine.style.opacity = '1';

        var topPt = c1.y < c2.y ? c1 : c2;
        var tipX = (topPt.x / 400) * 100;
        var tipY = (topPt.y / 190) * 100;
        tooltip.style.left = tipX + '%';
        tooltip.style.top = tipY + '%';
        tooltip.classList.remove('hidden');
        tooltipVal1.textContent = c1.val.toLocaleString();
        tooltipVal2.textContent = c2.val.toLocaleString();
      });

      chartContainer.addEventListener('mouseleave', function () {
        dot.style.opacity = '0';
        dot2.style.opacity = '0';
        scrubLine.style.opacity = '0';
        tooltip.classList.add('hidden');
      });
    });
  })();
</script>
