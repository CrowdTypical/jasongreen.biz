---

---

<section
  id="resume"
  class="relative z-10 bg-white py-16 md:py-24 px-6 md:px-16"
>
  <div class="max-w-5xl mx-auto">
    <!-- Section heading -->
    <p class="font-script text-sm md:text-base text-slate-400 mb-1">
      Career journey
    </p>
    <h2 class="font-heading text-3xl md:text-5xl font-bold text-slate-900 mb-12">
      Resume
    </h2>

    <div class="grid md:grid-cols-2 gap-12">
      <!-- Experience Timeline -->
      <div>
        <h3
          class="font-sans text-sm font-semibold uppercase tracking-wider text-slate-400 mb-8"
        >
          Experience
        </h3>

        <div class="space-y-0">
          <div class="timeline-item">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <p class="text-sm font-medium text-slate-400 mb-1">2023 – 2025</p>
              <h4 class="font-semibold text-slate-900 mb-1">
                Sr. Experimentation Solutions Manager
              </h4>
              <p class="text-sm text-slate-500">Shopify</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <p class="text-sm font-medium text-slate-400 mb-1">2021 – 2023</p>
              <h4 class="font-semibold text-slate-900 mb-1">
                Product Support Network Specialist
              </h4>
              <p class="text-sm text-slate-500">Shopify</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <p class="text-sm font-medium text-slate-400 mb-1">2020 – 2021</p>
              <h4 class="font-semibold text-slate-900 mb-1">Support Advisor</h4>
              <p class="text-sm text-slate-500">Shopify</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <p class="text-sm font-medium text-slate-400 mb-1">2019 – 2020</p>
              <h4 class="font-semibold text-slate-900 mb-1">
                Part Support Coordinator
              </h4>
              <p class="text-sm text-slate-500">Napoleon</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <p class="text-sm font-medium text-slate-400 mb-1">2017 – 2019</p>
              <h4 class="font-semibold text-slate-900 mb-1">Product Advisor</h4>
              <p class="text-sm text-slate-500">Napoleon</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <p class="text-sm font-medium text-slate-400 mb-1">2015 – 2017</p>
              <h4 class="font-semibold text-slate-900 mb-1">
                Program Coordinator & Team Leader
              </h4>
              <p class="text-sm text-slate-500">Transcom</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Skills Grid -->
      <div>
        <h3
          class="font-sans text-sm font-semibold uppercase tracking-wider text-slate-400 mb-8"
        >
          Skills
        </h3>

        <div class="space-y-8">
          <div>
            <h4 class="font-medium text-slate-900 text-sm mb-3">
              Data & Analytics
            </h4>
            <div class="flex flex-wrap gap-2">
              <span class="skill-tag">SQL</span>
              <span class="skill-tag">BigQuery</span>
              <span class="skill-tag">Looker Studio</span>
              <span class="skill-tag">Data Visualization</span>
            </div>
          </div>

          <div>
            <h4 class="font-medium text-slate-900 text-sm mb-3">
              Automation & Tooling
            </h4>
            <div class="flex flex-wrap gap-2">
              <span class="skill-tag">App Script</span>
              <span class="skill-tag">AppSheet</span>
              <span class="skill-tag">Workflow Automation</span>
              <span class="skill-tag">AI Integration</span>
            </div>
          </div>

          <div>
            <h4 class="font-medium text-slate-900 text-sm mb-3">
              Strategy & Operations
            </h4>
            <div class="flex flex-wrap gap-2">
              <span class="skill-tag">KPI Development</span>
              <span class="skill-tag">Process Optimization</span>
              <span class="skill-tag">Experimentation Design</span>
              <span class="skill-tag">Product Strategy</span>
            </div>
          </div>

          <div>
            <h4 class="font-medium text-slate-900 text-sm mb-3">Leadership</h4>
            <div class="flex flex-wrap gap-2">
              <span class="skill-tag">Cross-Functional Teams</span>
              <span class="skill-tag">Stakeholder Enablement</span>
              <span class="skill-tag">Coaching</span>
              <span class="skill-tag">Team Building</span>
            </div>
          </div>
        </div>

        <!-- Download CTA -->
        <div class="mt-8">
          <a
            href="/resume.pdf"
            class="inline-flex items-center gap-2 px-6 py-3 bg-blue-900 text-white rounded-full font-medium text-sm hover:bg-blue-800 transition-colors"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3"
              ></path></svg
            >
            Download Resume (PDF)
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Timeline */
  .timeline-item {
    position: relative;
    padding-left: 2rem;
    padding-bottom: 2rem;
    border-left: 2px solid #cbd5e1;
  }
  .timeline-item:last-child {
    border-left-color: transparent;
    padding-bottom: 0;
  }
  .timeline-dot {
    position: absolute;
    left: -5px;
    top: 2px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #1e3a8a;
  }
  .timeline-content {
    padding-top: 0;
  }

  /* Skill tags */
  .skill-tag {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.8125rem;
    font-weight: 500;
    color: #334155;
    background: #f1f5f9;
    border: 1px solid #cbd5e1;
  }
</style>
