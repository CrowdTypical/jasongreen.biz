---
interface Props {
  category: string;
  categoryColor: 'emerald' | 'blue' | 'purple' | 'amber';
  title: string;
  tags: string[];
}

const { category, categoryColor, title, tags } = Astro.props;

const colorClasses = {
  emerald: 'text-emerald-400 bg-emerald-400/10',
  blue: 'text-blue-400 bg-blue-400/10',
  purple: 'text-purple-400 bg-purple-400/10',
  amber: 'text-amber-400 bg-amber-400/10',
} as const;

const badgeColor = colorClasses[categoryColor];
---

<div
  class="work-panel shrink-0 w-screen h-full flex items-center justify-center px-4 md:px-16 py-2 pb-14 md:pb-4 md:py-4"
>
  <!-- Card — sizes to content, caps at available height, scrolls if needed -->
  <div class="max-w-6xl w-full max-h-[calc(100dvh-18rem)] md:max-h-full flex flex-col rounded-3xl bg-slate-800/60 border border-slate-700/50 backdrop-blur-sm overflow-hidden">
    <!-- Card header — fixed at top, never scrolls -->
    <div class="shrink-0 px-6 md:px-12 pt-6 md:pt-12">
      <div class="md:hidden">
        <span
          class={`inline-block px-3 py-1 text-sm font-semibold uppercase tracking-wider ${badgeColor} rounded-full mb-3`}
        >
          {category}
        </span>
        <h3 class="font-serif text-3xl font-bold text-white mb-4">
          {title}
        </h3>
      </div>
    </div>

    <!-- Card content — scrollable on mobile -->
    <div class="min-h-0 overflow-y-auto md:overflow-visible px-6 pb-6 md:p-12 md:pt-0">
      <div class="grid md:grid-cols-2 gap-8">
        <div class="flex flex-col justify-center">
          <!-- Desktop-only header (inside grid) -->
          <span
            class={`hidden md:inline-block px-3 py-1 text-sm font-semibold uppercase tracking-wider ${badgeColor} rounded-full mb-5`}
          >
            {category}
          </span>
          <h3
            class="hidden md:block font-serif md:text-5xl font-bold text-white mb-5"
          >
            {title}
          </h3>
          <slot name="description" />
          <div class="flex flex-wrap gap-2">
            {tags.map((tag) => <span class="tag">{tag}</span>)}
          </div>
        </div>

        <!-- Mobile preview (collapsible) -->
        <div class="preview-mobile md:hidden">
          <div class="pt-4 pb-2 rounded-2xl">
            <slot />
          </div>
        </div>

        <!-- Desktop preview -->
        <div class="hidden md:flex items-stretch">
          <slot />
        </div>
      </div>
    </div>

    <!-- Mobile preview toggle bar -->
    <button
      class="preview-toggle md:hidden shrink-0 w-full py-3 bg-slate-700/40 border-t border-slate-700/50 flex items-center justify-center text-slate-400 hover:text-slate-200 hover:bg-slate-700/60 transition-all"
      type="button"
      aria-expanded="false"
      aria-label="Toggle preview"
    >
      <svg class="preview-toggle-icon w-5 h-5 transition-transform duration-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
    </button>
  </div>
</div>

<style>
  .tag {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 500;
    color: #94a3b8;
    background: rgba(148, 163, 184, 0.1);
    border: 1px solid rgba(148, 163, 184, 0.2);
  }

  .preview-mobile {
    display: none;
  }

  .preview-mobile.is-open {
    display: block;
  }

  .preview-toggle[aria-expanded='true'] .preview-toggle-icon {
    transform: rotate(45deg);
  }
</style>

<script>
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.preview-toggle');
    if (!btn) return;

    const panel = btn.closest('.work-panel');
    if (!panel) return;

    const preview = panel.querySelector('.preview-mobile');
    if (!preview) return;

    const isOpen = preview.classList.toggle('is-open');
    btn.setAttribute('aria-expanded', String(isOpen));
  });
</script>
