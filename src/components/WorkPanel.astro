---
interface Props {
  category: string;
  categoryColor: 'emerald' | 'blue' | 'purple' | 'amber';
  title: string;
  tags: string[];
}

const { category, categoryColor, title, tags } = Astro.props;

const colorClasses = {
  emerald: 'text-emerald-400 bg-emerald-400/10',
  blue: 'text-blue-400 bg-blue-400/10',
  purple: 'text-purple-400 bg-purple-400/10',
  amber: 'text-amber-400 bg-amber-400/10',
} as const;

const badgeColor = colorClasses[categoryColor];
---

<div
  class="work-panel shrink-0 w-screen h-full flex items-center justify-center px-8 md:px-20"
>
  <div class="max-w-5xl w-full grid md:grid-cols-2 gap-8 items-center">
    <div>
      <span
        class={`inline-block px-3 py-1 text-xs font-semibold uppercase tracking-wider ${badgeColor} rounded-full mb-4`}
      >
        {category}
      </span>
      <h3
        class="font-serif text-3xl md:text-4xl font-bold text-white mb-4"
      >
        {title}
      </h3>
      <slot name="description" />
      <div class="flex flex-wrap gap-2">
        {tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
    </div>
    <div class="hidden md:flex items-center justify-center">
      <slot />
    </div>
  </div>
</div>

<style>
  .tag {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
    color: #94a3b8;
    background: rgba(148, 163, 184, 0.1);
    border: 1px solid rgba(148, 163, 184, 0.2);
  }
</style>
