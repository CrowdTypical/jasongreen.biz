---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden bg-white">
	<!-- Soft pastel gradient blobs -->
	<div class="blob blob-pink"></div>
	<div class="blob blob-green"></div>
	<div class="blob blob-blue"></div>
	<div class="blob blob-yellow"></div>

	<!-- Content -->
	<div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
		<p class="font-script text-lg md:text-xl text-gray-400 mb-6 tracking-wide animate-fade-in">
			Product & Operations Leader
		</p>

		<h1 class="font-serif text-5xl md:text-7xl lg:text-8xl font-bold text-gray-900 leading-[0.95] mb-8 animate-fade-in-up">
			Jason Green
		</h1>

		<p class="font-sans text-lg md:text-xl text-gray-500 max-w-2xl mx-auto leading-relaxed mb-12 animate-fade-in-up delay-100">
			Turning complex operations into streamlined systems. 10+ years leading teams,
			building tools, and driving data-informed decisions at companies like Shopify.
		</p>

		<!-- Highlight pills -->
		<div class="flex flex-wrap items-center justify-center gap-3 mb-14 animate-fade-in-up delay-200">
			<span class="pill">Experimentation Design</span>
			<span class="pill">Cross-Functional Leadership</span>
			<span class="pill">Data & Analytics</span>
			<span class="pill">Process Automation</span>
			<span class="pill">Product Strategy</span>
		</div>

		<!-- CTAs -->
		<div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-in-up delay-300">
			<a href="#work" class="px-8 py-3 bg-gray-900 text-white rounded-full font-medium text-sm hover:bg-gray-700 transition-colors">
				View My Work
			</a>
			<a href="#contact" class="px-8 py-3 border border-gray-300 text-gray-700 rounded-full font-medium text-sm hover:border-gray-900 hover:text-gray-900 transition-colors">
				Get In Touch
			</a>
		</div>

		<!-- Social links -->
		<div class="flex items-center justify-center gap-6 mt-12 text-gray-400 animate-fade-in-up delay-300">
			<a href="https://github.com/CrowdTypical" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="hover:text-gray-900 transition-colors">
				<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
			</a>
			<a href="https://linkedin.com/in/jasonkgreen" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="hover:text-gray-900 transition-colors">
				<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
			</a>
			<a href="mailto:contact@jasongreen.biz" aria-label="Email" class="hover:text-gray-900 transition-colors">
				<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" /></svg>
			</a>
		</div>
	</div>

	<!-- Scroll indicator -->
	<div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce">
		<svg class="w-6 h-6 text-gray-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
			<path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
		</svg>
	</div>
</section>

<style>
	.pill {
		display: inline-block;
		padding: 0.375rem 1rem;
		border-radius: 9999px;
		font-size: 0.8125rem;
		font-weight: 500;
		color: #4b5563;
		background: #f3f4f6;
		border: 1px solid #e5e7eb;
		font-family: 'Inter', system-ui, sans-serif;
	}

	/* Blob styles */
	.blob {
		position: absolute;
		border-radius: 50%;
		filter: blur(80px);
		opacity: 0.45;
		animation: float 20s ease-in-out infinite;
	}
	.blob-pink {
		width: 340px;
		height: 340px;
		background: radial-gradient(circle, #f0b4f0, #f5d0f5);
		top: -5%;
		right: 25%;
		animation-delay: 0s;
	}
	.blob-green {
		width: 280px;
		height: 280px;
		background: radial-gradient(circle, #b8e6c8, #d4f0dc);
		top: 20%;
		left: 8%;
		animation-delay: -5s;
	}
	.blob-blue {
		width: 240px;
		height: 240px;
		background: radial-gradient(circle, #b8dff0, #d0ecf8);
		top: 5%;
		right: 5%;
		animation-delay: -10s;
	}
	.blob-yellow {
		width: 320px;
		height: 320px;
		background: radial-gradient(circle, #f5e6a0, #faf0c8);
		bottom: -5%;
		right: 15%;
		animation-delay: -15s;
	}

	@keyframes float {
		0%, 100% { transform: translate(0, 0) scale(1); }
		25% { transform: translate(30px, -20px) scale(1.05); }
		50% { transform: translate(-20px, 15px) scale(0.95); }
		75% { transform: translate(15px, 25px) scale(1.02); }
	}

	/* Entry animations */
	.animate-fade-in {
		animation: fadeIn 0.8s ease-out both;
	}
	.animate-fade-in-up {
		animation: fadeInUp 0.8s ease-out both;
	}
	.delay-100 { animation-delay: 0.1s; }
	.delay-200 { animation-delay: 0.2s; }
	.delay-300 { animation-delay: 0.3s; }

	@keyframes fadeIn {
		from { opacity: 0; }
		to { opacity: 1; }
	}
	@keyframes fadeInUp {
		from { opacity: 0; transform: translateY(20px); }
		to { opacity: 1; transform: translateY(0); }
	}
</style>
