---

---

<section
  id="hero"
  class="relative min-h-screen flex items-center justify-center overflow-hidden bg-transparent"
>
  <!-- Content -->
  <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
    <p
      class="font-script text-lg md:text-xl text-blue-900/70 mb-6 tracking-wide animate-fade-in"
    >
      Product & Operations Leader
    </p>

    <h1
      class="font-heading text-5xl md:text-7xl lg:text-8xl font-bold text-slate-900 leading-[0.95] mb-8 animate-fade-in-up"
    >
      Jason Green
    </h1>

    <p
      class="font-sans text-lg md:text-xl text-slate-600 max-w-2xl mx-auto leading-relaxed mb-8 animate-fade-in-up delay-100"
    >
      Turning complex operations into streamlined systems. 10+ years leading
      teams, building tools, and driving data-informed decisions at companies
      like Shopify.
    </p>

    <!-- Highlight pills -->
    <div
      class="flex flex-wrap items-center justify-center gap-3 mb-14 animate-fade-in-up delay-200"
    >
      <span class="pill">Experimentation Design</span>
      <span class="pill">Cross-Functional Leadership</span>
      <span class="pill">Data & Analytics</span>
      <span class="pill">Process Automation</span>
      <span class="pill">Product Strategy</span>
    </div>

    <!-- CTAs -->
    <div
      class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-in-up delay-300"
    >
      <a
        href="#work"
        class="px-8 py-3 bg-blue-900 text-white rounded-full font-medium text-sm hover:bg-blue-800 transition-colors"
      >
        View My Work
      </a>
      <a
        href="#contact"
        class="px-8 py-3 bg-white border-2 border-blue-900 text-blue-900 rounded-full font-medium text-sm hover:bg-blue-900 hover:text-white transition-colors"
      >
        Get In Touch
      </a>
    </div>

    <!-- Social links -->
    <div
      class="flex items-center justify-center gap-6 mt-8 text-slate-500 animate-fade-in-up delay-300"
    >
      <a
        href="https://github.com/CrowdTypical"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="hover:text-slate-900 transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
          ><path
            d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
          ></path></svg
        >
      </a>
      <a
        href="https://www.linkedin.com/in/jasonkirbygreen"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="hover:text-slate-900 transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
          ><path
            d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
          ></path></svg
        >
      </a>
      <a
        href="mailto:contact@jasongreen.biz"
        aria-label="Email"
        class="hover:text-slate-900 transition-colors"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
          ></path></svg
        >
      </a>
    </div>
  </div>

  <!-- Scroll indicator — fades out as user scrolls through hero -->
  <div
    id="scroll-arrow"
    class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce transition-opacity duration-300"
  >
    <svg
      class="w-8 h-8 text-blue-900/60"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </div>
</section>

<script>
  const scrollArrow = document.getElementById('scroll-arrow');
  const heroSection = document.getElementById('hero');
  if (scrollArrow && heroSection) {
    window.addEventListener(
      'scroll',
      () => {
        const heroHeight = heroSection.offsetHeight;
        const halfway = heroHeight * 0.5;
        // Fade from full opacity at 0 scroll to 0 at 50% of hero
        const opacity = Math.max(0, 1 - window.scrollY / halfway);
        scrollArrow.style.opacity = String(opacity);
      },
      { passive: true }
    );
  }
</script>

<style>
  .pill {
    display: inline-block;
    padding: 0.375rem 1rem;
    border-radius: 9999px;
    font-size: 0.8125rem;
    font-weight: 500;
    color: #334155;
    background: #f1f5f9;
    border: 1px solid #cbd5e1;
  }

  /* Blob styles — removed, now handled globally */

  /* Entry animations */
  .animate-fade-in {
    animation: fadeIn 0.8s ease-out both;
  }
  .animate-fade-in-up {
    animation: fadeInUp 0.8s ease-out both;
  }
  .delay-100 {
    animation-delay: 0.1s;
  }
  .delay-200 {
    animation-delay: 0.2s;
  }
  .delay-300 {
    animation-delay: 0.3s;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
