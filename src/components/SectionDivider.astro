---
interface Props {
	flip?: boolean;
	fromColor?: string;
	toColor?: string;
}

const { flip = false, fromColor = '#ffffff', toColor = '#0f172a' } = Astro.props;
---

<div class={`section-divider w-full overflow-hidden leading-none ${flip ? 'rotate-180' : ''}`} style={`background: transparent;`}>
	<svg
		viewBox="0 0 1440 200"
		preserveAspectRatio="none"
		class="w-full h-[80px] md:h-[120px] lg:h-[160px] block"
		xmlns="http://www.w3.org/2000/svg"
	>
		<!-- Back layer — starts from top, full coverage -->
		<path
			d="M0,0 C360,60 720,0 1080,30 C1260,50 1380,10 1440,0 L1440,200 L0,200 Z"
			fill={toColor}
			opacity="0.25"
		>
			<animate attributeName="d" dur="8s" repeatCount="indefinite" values="
				M0,0 C360,60 720,0 1080,30 C1260,50 1380,10 1440,0 L1440,200 L0,200 Z;
				M0,10 C300,0 600,50 900,15 C1200,0 1350,40 1440,5 L1440,200 L0,200 Z;
				M0,0 C400,45 700,0 1000,35 C1280,55 1400,5 1440,0 L1440,200 L0,200 Z;
				M0,0 C360,60 720,0 1080,30 C1260,50 1380,10 1440,0 L1440,200 L0,200 Z
			" />
		</path>
		<!-- Middle layer — offset wave -->
		<path
			d="M0,50 C200,20 400,90 720,55 C1040,15 1240,80 1440,40 L1440,200 L0,200 Z"
			fill={toColor}
			opacity="0.5"
		>
			<animate attributeName="d" dur="10s" repeatCount="indefinite" values="
				M0,50 C200,20 400,90 720,55 C1040,15 1240,80 1440,40 L1440,200 L0,200 Z;
				M0,40 C240,80 500,15 750,60 C1000,100 1280,25 1440,50 L1440,200 L0,200 Z;
				M0,60 C180,10 450,80 700,40 C1050,5 1200,90 1440,35 L1440,200 L0,200 Z;
				M0,50 C200,20 400,90 720,55 C1040,15 1240,80 1440,40 L1440,200 L0,200 Z
			" />
		</path>
		<!-- Front layer — primary wave -->
		<path
			d="M0,100 C240,135 480,70 720,100 C960,135 1200,70 1440,90 L1440,200 L0,200 Z"
			fill={toColor}
		>
			<animate attributeName="d" dur="12s" repeatCount="indefinite" values="
				M0,100 C240,135 480,70 720,100 C960,135 1200,70 1440,90 L1440,200 L0,200 Z;
				M0,110 C300,75 520,130 740,95 C980,55 1180,120 1440,100 L1440,200 L0,200 Z;
				M0,95 C280,125 500,70 730,105 C940,135 1220,60 1440,85 L1440,200 L0,200 Z;
				M0,100 C240,135 480,70 720,100 C960,135 1200,70 1440,90 L1440,200 L0,200 Z
			" />
		</path>
	</svg>
</div>

<style>
	.section-divider {
		line-height: 0;
		margin-top: -10px;
		margin-bottom: -3px;
		position: relative;
		z-index: 1;
	}
</style>
