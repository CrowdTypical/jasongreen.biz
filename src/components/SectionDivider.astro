---
interface Props {
	flip?: boolean;
	fromColor?: string;
	toColor?: string;
}

const { flip = false, fromColor = '#ffffff', toColor = '#0f172a' } = Astro.props;
---

<div class={`section-divider w-full overflow-hidden leading-none ${flip ? 'rotate-180' : ''}`} style={`background: ${fromColor};`}>
	<svg
		viewBox="0 0 1440 200"
		preserveAspectRatio="none"
		class="w-full h-[80px] md:h-[120px] lg:h-[160px] block"
		xmlns="http://www.w3.org/2000/svg"
	>
		<!-- Back layer — gentle wave -->
		<path
			d="M0,100 C360,160 720,40 1080,100 C1260,130 1380,80 1440,90 L1440,200 L0,200 Z"
			fill={toColor}
			opacity="0.3"
		/>
		<!-- Middle layer — offset wave -->
		<path
			d="M0,120 C200,80 400,160 720,110 C1040,60 1240,140 1440,100 L1440,200 L0,200 Z"
			fill={toColor}
			opacity="0.5"
		/>
		<!-- Front layer — primary wave -->
		<path
			d="M0,140 C240,180 480,100 720,140 C960,180 1200,100 1440,130 L1440,200 L0,200 Z"
			fill={toColor}
		/>
	</svg>
</div>

<style>
	.section-divider {
		line-height: 0;
		margin-top: -1px;
		margin-bottom: -1px;
	}
</style>
