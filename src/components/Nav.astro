---

---

<nav
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo / Name — hidden until hero name scrolls out of view -->
    <a
      id="nav-brand"
      href="#hero"
      class="flex items-center gap-2 font-serif text-xl font-bold text-slate-900 hover:text-blue-900 transition-all duration-300 opacity-0 -translate-y-2 pointer-events-none"
    >
      <img src="/jgiconlogo.svg" alt="" class="h-7 w-auto" width="28" height="28" />
      Jason Green
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-8">
      <a
        href="#hero"
        class="nav-link text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors"
        >Home</a
      >
      <a
        href="#work"
        class="nav-link text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors"
        >Work</a
      >
      <a
        href="#resume"
        class="nav-link text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors"
        >Resume</a
      >
      <!-- Projects Dropdown -->
      <div class="relative" id="app-support-dropdown">
        <button
          class="nav-link text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors flex items-center gap-1"
          id="app-support-btn"
          aria-expanded="false"
          aria-haspopup="true"
        >
          Projects
          <svg
            class="w-3.5 h-3.5 transition-transform duration-200"
            id="dropdown-chevron"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="m19.5 8.25-7.5 7.5-7.5-7.5"></path></svg
          >
        </button>
        <div
          id="dropdown-menu"
          class="absolute top-full right-0 mt-2 w-52 bg-white rounded-lg shadow-lg border border-slate-100 opacity-0 invisible translate-y-1 transition-all duration-200 overflow-hidden"
        >
          <a
            href="/spread-the-fund"
            class="page-transition-right flex items-center gap-3 px-4 py-3 text-sm font-medium text-slate-600 hover:bg-slate-50 hover:text-slate-900 transition-colors"
          >
            <img
              src="/spread-the-fund/glitch_dollar_icon.webp"
              alt=""
              class="w-5 h-5"
              width="20"
              height="20"
            />
            Spread the Funds
          </a>
          <a
            href="/careertools"
            class="flex items-center gap-3 px-4 py-3 text-sm font-medium text-slate-600 hover:bg-slate-50 hover:text-slate-900 transition-colors"
          >
            <svg class="w-5 h-5 text-blue-500" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M6 3.75A2.75 2.75 0 0 1 8.75 1h2.5A2.75 2.75 0 0 1 14 3.75v.443c.572.055 1.14.122 1.706.2C17.053 4.582 18 5.75 18 7.07v3.469c0 1.126-.694 2.191-1.83 2.494l-1.92.518-.489.132A6.5 6.5 0 0 1 10 14a6.5 6.5 0 0 1-3.761-1.317l-.489-.132-1.92-.518C2.694 11.73 2 10.665 2 9.539V7.071c0-1.321.947-2.489 2.294-2.678A32.5 32.5 0 0 1 6 4.193V3.75Zm2.5-1A1.25 1.25 0 0 0 7.25 3.75v.255c.88-.06 1.762-.09 2.75-.09s1.87.03 2.75.09V3.75A1.25 1.25 0 0 0 11.25 2.75h-2.5ZM10 8a1 1 0 0 0-1 1v.01a1 1 0 1 0 2 0V9a1 1 0 0 0-1-1Z" clip-rule="evenodd"/>
              <path d="M3.135 14.455a32 32 0 0 0 3.57 1.395A6 6 0 0 0 10 16.5a6 6 0 0 0 3.295-.65 32 32 0 0 0 3.57-1.395c.232-.098.47-.192.712-.28A.75.75 0 0 1 18 15.5v.03a2.75 2.75 0 0 1-2.25 2.697l-.652.14a60 60 0 0 1-10.197 0l-.651-.14A2.75 2.75 0 0 1 2 15.53V15.5a.75.75 0 0 1 .423-.67c.242.088.48.182.712.28Z"/>
            </svg>
            Career Tools
          </a>
        </div>
      </div>
      <a
        href="#contact"
        class="nav-link text-sm font-medium text-blue-900 transition-colors bg-white border-2 border-blue-900 px-4 py-2 rounded-full hover:bg-blue-900 hover:text-white"
      >
        Let's Talk
      </a>
    </div>

    <!-- Mobile Hamburger -->
    <button
      id="menu-toggle"
      class="md:hidden flex flex-col gap-1.5 p-2 -mr-2"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
    >
      <span
        class="hamburger-line block w-6 h-0.5 bg-slate-900 transition-all duration-300 origin-center"
      ></span>
      <span
        class="hamburger-line block w-6 h-0.5 bg-slate-900 transition-all duration-300 origin-center"
      ></span>
      <span
        class="hamburger-line block w-6 h-0.5 bg-slate-900 transition-all duration-300 origin-center"
      ></span>
    </button>
  </div>

  <!-- Mobile Menu Overlay -->
  <div
    id="mobile-menu"
    class="md:hidden fixed inset-0 top-0 bg-white z-40 flex flex-col items-center justify-center gap-8 opacity-0 pointer-events-none transition-opacity duration-300"
  >
    <a
      href="#hero"
      class="mobile-nav-link font-serif text-3xl text-slate-900 hover:text-slate-600 transition-colors"
      >Home</a
    >
    <a
      href="#work"
      class="mobile-nav-link font-serif text-3xl text-slate-900 hover:text-slate-600 transition-colors"
      >Work</a
    >
    <a
      href="#resume"
      class="mobile-nav-link font-serif text-3xl text-slate-900 hover:text-slate-600 transition-colors"
      >Resume</a
    >
    <!-- Mobile Projects Section -->
    <div class="flex flex-col items-center gap-3">
      <span class="font-serif text-3xl text-slate-400">Projects</span>
      <a
        href="/spread-the-fund"
        class="page-transition-right mobile-nav-link flex items-center gap-3 font-serif text-xl text-slate-600 hover:text-slate-900 transition-colors"
      >
        <img src="/spread-the-fund/glitch_dollar_icon.webp" alt="" class="w-6 h-6" />
        Spread the Funds
      </a>
      <a
        href="/careertools"
        class="mobile-nav-link flex items-center gap-3 font-serif text-xl text-slate-600 hover:text-slate-900 transition-colors"
      >
        <svg class="w-6 h-6 text-blue-500" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M6 3.75A2.75 2.75 0 0 1 8.75 1h2.5A2.75 2.75 0 0 1 14 3.75v.443c.572.055 1.14.122 1.706.2C17.053 4.582 18 5.75 18 7.07v3.469c0 1.126-.694 2.191-1.83 2.494l-1.92.518-.489.132A6.5 6.5 0 0 1 10 14a6.5 6.5 0 0 1-3.761-1.317l-.489-.132-1.92-.518C2.694 11.73 2 10.665 2 9.539V7.071c0-1.321.947-2.489 2.294-2.678A32.5 32.5 0 0 1 6 4.193V3.75Zm2.5-1A1.25 1.25 0 0 0 7.25 3.75v.255c.88-.06 1.762-.09 2.75-.09s1.87.03 2.75.09V3.75A1.25 1.25 0 0 0 11.25 2.75h-2.5ZM10 8a1 1 0 0 0-1 1v.01a1 1 0 1 0 2 0V9a1 1 0 0 0-1-1Z" clip-rule="evenodd"/>
          <path d="M3.135 14.455a32 32 0 0 0 3.57 1.395A6 6 0 0 0 10 16.5a6 6 0 0 0 3.295-.65 32 32 0 0 0 3.57-1.395c.232-.098.47-.192.712-.28A.75.75 0 0 1 18 15.5v.03a2.75 2.75 0 0 1-2.25 2.697l-.652.14a60 60 0 0 1-10.197 0l-.651-.14A2.75 2.75 0 0 1 2 15.53V15.5a.75.75 0 0 1 .423-.67c.242.088.48.182.712.28Z"/>
        </svg>
        Career Tools
      </a>
    </div>
    <a
      href="#contact"
      class="mobile-nav-link font-serif text-3xl text-slate-900 hover:text-slate-600 transition-colors"
      >Contact</a
    >
  </div>
</nav>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const mobileLinks = menu?.querySelectorAll('.mobile-nav-link');
  const nav = document.getElementById('main-nav');
  let isOpen = false;

  function openMenu() {
    isOpen = true;
    toggle?.setAttribute('aria-expanded', 'true');
    menu?.classList.remove('opacity-0', 'pointer-events-none');
    menu?.classList.add('opacity-100', 'pointer-events-auto');
    document.body.style.overflow = 'hidden';
    // Animate hamburger to X
    const lines = toggle?.querySelectorAll('.hamburger-line');
    if (lines) {
      (lines[0] as HTMLElement).style.transform =
        'rotate(45deg) translate(3px, 3px)';
      (lines[1] as HTMLElement).style.opacity = '0';
      (lines[2] as HTMLElement).style.transform =
        'rotate(-45deg) translate(3px, -3px)';
    }
  }

  function closeMenu() {
    isOpen = false;
    toggle?.setAttribute('aria-expanded', 'false');
    menu?.classList.add('opacity-0', 'pointer-events-none');
    menu?.classList.remove('opacity-100', 'pointer-events-auto');
    document.body.style.overflow = '';
    // Animate X back to hamburger
    const lines = toggle?.querySelectorAll('.hamburger-line');
    if (lines) {
      (lines[0] as HTMLElement).style.transform = '';
      (lines[1] as HTMLElement).style.opacity = '1';
      (lines[2] as HTMLElement).style.transform = '';
    }
  }

  toggle?.addEventListener('click', () => {
    if (isOpen) closeMenu();
    else openMenu();
  });

  mobileLinks?.forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  // Show/hide nav brand based on hero name visibility
  const navBrand = document.getElementById('nav-brand');
  const heroHeading = document.querySelector('#hero h1');

  if (heroHeading && navBrand) {
    const brandObserver = new IntersectionObserver(
      (entries) => {
        const heroVisible = entries[0].isIntersecting;
        if (heroVisible) {
          // Hero name on screen — hide nav brand
          navBrand.classList.add(
            'opacity-0',
            '-translate-y-2',
            'pointer-events-none'
          );
          navBrand.classList.remove(
            'opacity-100',
            'translate-y-0',
            'pointer-events-auto'
          );
        } else {
          // Hero name scrolled away — show nav brand
          navBrand.classList.remove(
            'opacity-0',
            '-translate-y-2',
            'pointer-events-none'
          );
          navBrand.classList.add(
            'opacity-100',
            'translate-y-0',
            'pointer-events-auto'
          );
        }
      },
      { threshold: 0 }
    );
    brandObserver.observe(heroHeading);
  }

  // Nav background on scroll
  // Fully opaque through hero + work, then semi-transparent after
  const workSection = document.getElementById('work');
  window.addEventListener(
    'scroll',
    () => {
      const scrollY = window.scrollY;
      const workBottom = workSection
        ? workSection.getBoundingClientRect().bottom + scrollY
        : 0;

      if (scrollY > 50 && scrollY < workBottom) {
        // Fully opaque through hero + work section
        nav?.classList.add('bg-white', 'shadow-sm');
        nav?.classList.remove('bg-white/90', 'backdrop-blur-md');
      } else if (scrollY >= workBottom) {
        // Semi-transparent after work section
        nav?.classList.add('bg-white/90', 'backdrop-blur-md', 'shadow-sm');
        nav?.classList.remove('bg-white');
      } else {
        // Top of page — transparent
        nav?.classList.remove(
          'bg-white',
          'bg-white/90',
          'backdrop-blur-md',
          'shadow-sm'
        );
      }
    },
    { passive: true }
  );

  // App Support dropdown
  const dropdownBtn = document.getElementById('app-support-btn');
  const dropdownMenu = document.getElementById('dropdown-menu');
  const dropdownChevron = document.getElementById('dropdown-chevron');
  const dropdownContainer = document.getElementById('app-support-dropdown');
  let dropdownOpen = false;

  function openDropdown() {
    dropdownOpen = true;
    dropdownBtn?.setAttribute('aria-expanded', 'true');
    dropdownMenu?.classList.remove('opacity-0', 'invisible', 'translate-y-1');
    dropdownMenu?.classList.add('opacity-100', 'visible', 'translate-y-0');
    dropdownChevron?.classList.add('rotate-180');
  }

  function closeDropdown() {
    dropdownOpen = false;
    dropdownBtn?.setAttribute('aria-expanded', 'false');
    dropdownMenu?.classList.add('opacity-0', 'invisible', 'translate-y-1');
    dropdownMenu?.classList.remove('opacity-100', 'visible', 'translate-y-0');
    dropdownChevron?.classList.remove('rotate-180');
  }

  dropdownBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    if (dropdownOpen) closeDropdown();
    else openDropdown();
  });

  document.addEventListener('click', (e) => {
    if (dropdownOpen && !dropdownContainer?.contains(e.target as Node)) {
      closeDropdown();
    }
  });

  // Page transition handling
  document.querySelectorAll('.page-transition-right').forEach((link) => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const href = (link as HTMLAnchorElement).href;
      sessionStorage.setItem('page-transition-dir', 'right');
      document.body.classList.add('page-exit-left');
      setTimeout(() => {
        window.location.href = href;
      }, 200);
    });
  });

  document.querySelectorAll('.page-transition-left').forEach((link) => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const href = (link as HTMLAnchorElement).href;
      sessionStorage.setItem('page-transition-dir', 'left');
      document.body.classList.add('page-exit-right');
      setTimeout(() => {
        window.location.href = href;
      }, 200);
    });
  });
</script>

<style>
  /* No-JS fallback: make nav usable without JavaScript */

  /* Show nav brand and give nav a solid background */
  :global(html:not(.js)) #nav-brand {
    opacity: 1 !important;
    transform: none !important;
    pointer-events: auto !important;
  }

  :global(html:not(.js)) #main-nav {
    background: white;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
  }

  /* Desktop dropdown opens on hover */
  :global(html:not(.js)) #app-support-dropdown:hover #dropdown-menu,
  :global(html:not(.js)) #app-support-dropdown:focus-within #dropdown-menu {
    opacity: 1 !important;
    visibility: visible !important;
    transform: translateY(0) !important;
  }

  /* Mobile: hide hamburger, show links inline */
  :global(html:not(.js)) #menu-toggle {
    display: none !important;
  }

  :global(html:not(.js)) #mobile-menu {
    position: static;
    opacity: 1 !important;
    pointer-events: auto !important;
    flex-direction: row;
    gap: 1.5rem;
    padding: 0.5rem 1.5rem;
    justify-content: center;
    background: white;
    border-top: 1px solid #e2e8f0;
  }

  :global(html:not(.js)) .mobile-nav-link {
    font-size: 0.875rem !important;
  }
</style>
