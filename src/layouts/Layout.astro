---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Jason Green — Product & Operations Leader',
  description = 'Portfolio of Jason Green — strategic product and operations leader with 10+ years of cross-functional experience at Shopify and beyond.',
  ogImage = '/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://jasongreen.biz');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:image" content={new URL(ogImage, canonicalURL.origin).href} />

    <title>{title}</title>
    <script is:inline>
      // Apply entry animation direction before first paint
      (function () {
        var dir = sessionStorage.getItem('page-transition-dir');
        sessionStorage.removeItem('page-transition-dir');
        if (dir === 'left')
          document.documentElement.classList.add('enter-from-left');
        else if (dir === 'right')
          document.documentElement.classList.add('enter-from-right');
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500;600;700&family=Dancing+Script:wght@400;500&family=JetBrains+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="relative bg-white text-slate-900 font-sans overflow-x-hidden">
    <slot />
  </body>
</html>
