---
import '../styles/global.css';
import '@fontsource/outfit/300.css';
import '@fontsource/outfit/400.css';
import '@fontsource/outfit/500.css';
import '@fontsource/outfit/600.css';
import '@fontsource/outfit/700.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/700.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Jason Green — Product & Operations Leader',
  description = 'Portfolio of Jason Green — strategic product and operations leader with 10+ years of cross-functional experience at Shopify and beyond.',
  ogImage = '/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/jgiconlogo.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:image" content={new URL(ogImage, canonicalURL.origin).href} />

    <!-- Structured Data for AI/Search -->
    <meta name="author" content="Jason Green" />
    <meta name="keywords" content="Jason Green, Product Manager, Operations Leader, Program Manager, Shopify, Flutter, Firebase, Data Analytics, KPI Reporting, Workflow Automation, Technical Leadership, Cross-functional Leadership" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Jason Green",
      "url": "https://jasongreen.biz",
      "email": "theJasonKGreen@gmail.com",
      "jobTitle": "Product & Operations Leader",
      "description": "Strategic product and operations leader with 10+ years of cross-functional experience. Skilled in program management, data-driven decision making, workflow automation, stakeholder communication, and building products from zero to one. Former Senior Operations Analyst at Shopify. Builds production-quality software (Flutter, Firebase, Astro) and manages digital communities.",
      "knowsAbout": [
        "Product Management",
        "Program Management",
        "Operations Management",
        "Data Analytics & KPI Reporting",
        "Workflow Automation",
        "Cross-functional Leadership",
        "Stakeholder Communication",
        "Flutter & Dart",
        "Firebase",
        "Astro & Web Development",
        "Community Building",
        "Process Improvement",
        "Technical Project Management"
      ],
      "worksFor": {
        "@type": "Organization",
        "name": "Available for opportunities"
      },
      "alumniOf": {
        "@type": "Organization",
        "name": "Shopify"
      },
      "sameAs": [
        "https://www.linkedin.com/in/jasonkirbygreen",
        "https://github.com/CrowdTypical"
      ]
    })} />

    <title>{title}</title>
    <script is:inline>
      // Mark that JS is available (enables JS-dependent layouts)
      document.documentElement.classList.add('js');
      // Apply entry animation direction before first paint
      (function () {
        var dir = sessionStorage.getItem('page-transition-dir');
        sessionStorage.removeItem('page-transition-dir');
        if (dir === 'left')
          document.documentElement.classList.add('enter-from-left');
        else if (dir === 'right')
          document.documentElement.classList.add('enter-from-right');
      })();
    </script>
  </head>
  <body class="relative bg-white text-slate-900 font-sans overflow-x-hidden">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:px-4 focus:py-2 focus:bg-slate-900 focus:text-white focus:rounded-md focus:outline-2 focus:outline-offset-2 focus:outline-blue-500"
    >
      Skip to main content
    </a>
    <slot />
  </body>
</html>
