---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import HeroSection from '../components/HeroSection.astro';
import SectionDivider from '../components/SectionDivider.astro';
import HorizontalWorkSection from '../components/HorizontalWorkSection.astro';
import ResumeSection from '../components/ResumeSection.astro';
import ContactSection from '../components/ContactSection.astro';
---

<Layout title="Jason Green — Product & Operations Leader">
	<!-- Dynamic floating background blobs (hero area only) -->
	<div id="blob-bg" class="absolute top-0 left-0 right-0 pointer-events-none overflow-hidden" style="height: calc(100vh + 160px); z-index: 1;" aria-hidden="true">
		<div class="floating-blob blob-1"></div>
		<div class="floating-blob blob-2"></div>
		<div class="floating-blob blob-3"></div>
		<div class="floating-blob blob-4"></div>
		<div class="floating-blob blob-5"></div>
	</div>

	<Nav />

	<!-- Hero: vertical scroll -->
	<HeroSection />

	<!-- Divider + Work wrapper (divider stays sticky through work scroll runway) -->
	<div class="relative">
		<!-- Divider: white → dark -->
		<SectionDivider fromColor="#ffffff" toColor="#0f172a" sticky />

		<!-- Work: horizontal scroll triggered by vertical scrolling -->
		<HorizontalWorkSection />
	</div>

	<!-- Divider: dark → white (visually connects to Work section above) -->
	<div class="relative z-10 -mt-1 bg-slate-900">
		<SectionDivider fromColor="#0f172a" toColor="#ffffff" />
	</div>

	<!-- Resume: back to vertical -->
	<ResumeSection />

	<!-- Contact + Footer -->
	<ContactSection />

	<style>
		.floating-blob {
			position: absolute;
			filter: blur(40px);
			opacity: 0.4;
			mix-blend-mode: multiply;
			will-change: transform, border-radius;
		}

		.blob-1 {
			width: 450px;
			height: 450px;
			background: #c98585;
			top: -8%;
			left: 15%;
			animation: drift-1 21s ease-in-out infinite, morph-1 17s ease-in-out infinite;
		}

		.blob-2 {
			width: 400px;
			height: 400px;
			background: #d4c86e;
			top: 5%;
			right: -3%;
			animation: drift-2 27s ease-in-out infinite, morph-2 19s ease-in-out infinite;
		}

		.blob-3 {
			width: 380px;
			height: 380px;
			background: #7fba95;
			top: 30%;
			left: -5%;
			animation: drift-3 24s ease-in-out infinite, morph-3 15s ease-in-out infinite;
		}

		.blob-4 {
			width: 500px;
			height: 500px;
			background: #7aa3c4;
			top: 50%;
			right: 10%;
			animation: drift-4 28s ease-in-out infinite, morph-4 21s ease-in-out infinite;
		}

		.blob-5 {
			width: 360px;
			height: 360px;
			background: #cc9db8;
			top: 65%;
			left: 25%;
			animation: drift-5 23s ease-in-out infinite, morph-5 18s ease-in-out infinite;
		}



		/* Lava-lamp organic shape morphing — extreme shapes */
		@keyframes morph-1 {
			0%, 100% { border-radius: 24% 76% 72% 28% / 18% 68% 32% 82%; }
			20% { border-radius: 78% 22% 28% 72% / 62% 20% 80% 38%; }
			40% { border-radius: 18% 82% 68% 32% / 32% 74% 26% 68%; }
			60% { border-radius: 72% 28% 22% 78% / 76% 30% 70% 24%; }
			80% { border-radius: 36% 64% 78% 22% / 22% 58% 42% 78%; }
		}

		@keyframes morph-2 {
			0%, 100% { border-radius: 76% 24% 18% 82% / 72% 22% 78% 28%; }
			20% { border-radius: 22% 78% 64% 36% / 28% 80% 20% 72%; }
			40% { border-radius: 68% 32% 82% 18% / 78% 26% 74% 22%; }
			60% { border-radius: 28% 72% 36% 64% / 20% 68% 32% 80%; }
			80% { border-radius: 82% 18% 24% 76% / 64% 36% 64% 36%; }
		}

		@keyframes morph-3 {
			0%, 100% { border-radius: 32% 68% 26% 74% / 68% 24% 76% 32%; }
			25% { border-radius: 80% 20% 74% 26% / 18% 76% 24% 82%; }
			50% { border-radius: 20% 80% 32% 68% / 74% 28% 72% 26%; }
			75% { border-radius: 68% 32% 80% 20% / 26% 64% 36% 74%; }
		}

		@keyframes morph-4 {
			0%, 100% { border-radius: 26% 74% 68% 32% / 42% 76% 24% 58%; }
			16% { border-radius: 80% 20% 22% 78% / 78% 18% 82% 22%; }
			33% { border-radius: 18% 82% 76% 24% / 24% 72% 28% 76%; }
			50% { border-radius: 74% 26% 32% 68% / 68% 32% 68% 32%; }
			66% { border-radius: 32% 68% 82% 18% / 20% 64% 36% 80%; }
			83% { border-radius: 64% 36% 20% 80% / 76% 24% 76% 24%; }
		}

		@keyframes morph-5 {
			0%, 100% { border-radius: 72% 28% 22% 78% / 26% 74% 26% 74%; }
			20% { border-radius: 22% 78% 76% 24% / 80% 20% 80% 20%; }
			40% { border-radius: 78% 22% 32% 68% / 32% 68% 32% 68%; }
			60% { border-radius: 28% 72% 68% 32% / 72% 28% 72% 28%; }
			80% { border-radius: 68% 32% 24% 76% / 24% 76% 24% 76%; }
		}



		/* Movement paths — wide sweeps for merging overlap */
		@keyframes drift-1 {
			0%, 100% { transform: translate(0, 0) scale(1); }
			20% { transform: translate(200px, 120px) scale(1.25); }
			40% { transform: translate(50px, 260px) scale(0.8); }
			60% { transform: translate(-140px, 160px) scale(1.2); }
			80% { transform: translate(-60px, -50px) scale(0.85); }
		}

		@keyframes drift-2 {
			0%, 100% { transform: translate(0, 0) scale(1); }
			20% { transform: translate(-180px, 100px) scale(0.82); }
			40% { transform: translate(-280px, 220px) scale(1.22); }
			60% { transform: translate(-100px, 320px) scale(0.78); }
			80% { transform: translate(80px, 140px) scale(1.15); }
		}

		@keyframes drift-3 {
			0%, 100% { transform: translate(0, 0) scale(1); }
			25% { transform: translate(240px, -80px) scale(1.2); }
			50% { transform: translate(340px, 120px) scale(0.8); }
			75% { transform: translate(100px, 200px) scale(1.15); }
		}

		@keyframes drift-4 {
			0%, 100% { transform: translate(0, 0) scale(1); }
			20% { transform: translate(-140px, -160px) scale(1.25); }
			40% { transform: translate(-300px, -60px) scale(0.78); }
			60% { transform: translate(-180px, 140px) scale(1.18); }
			80% { transform: translate(60px, 60px) scale(0.85); }
		}

		@keyframes drift-5 {
			0%, 100% { transform: translate(0, 0) scale(1); }
			20% { transform: translate(100px, -200px) scale(0.82); }
			40% { transform: translate(260px, -100px) scale(1.22); }
			60% { transform: translate(180px, 80px) scale(0.8); }
			80% { transform: translate(-50px, -60px) scale(1.16); }
		}



		/* Reduce motion for accessibility */
		@media (prefers-reduced-motion: reduce) {
			.floating-blob {
				animation: none !important;
			}
		}
	</style>

	<script>
		(() => {
			if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

			const blobBg = document.getElementById('blob-bg');
			if (!blobBg) return;

			const blobs = blobBg.querySelectorAll<HTMLElement>('.floating-blob');
			if (blobs.length === 0) return;

			const REPEL_RADIUS = 500;
			const REPEL_FORCE = 18;      // push per frame (accumulates)
			const RETURN_EASE = 0.02;    // slow drift back when mouse is gone

			let mouseX = -9999;
			let mouseY = -9999;
			let active = false;
			let rafId: number | null = null;

			const state = Array.from(blobs, () => ({
				x: 0, y: 0,       // accumulated offset
				paused: false,     // whether drift animation is paused
			}));

			function tick() {
				blobs.forEach((blob, i) => {
					const s = state[i];
					const rect = blob.getBoundingClientRect();
					const cx = rect.left + rect.width / 2;
					const cy = rect.top + rect.height / 2;

					const dx = cx - mouseX;
					const dy = cy - mouseY;
					const dist = Math.sqrt(dx * dx + dy * dy);

					const inRange = active && dist < REPEL_RADIUS && dist > 1;

					if (inRange) {
						// Pause drift so mouse has full control
						if (!s.paused) {
							blob.style.animationPlayState = 'paused, running';
							s.paused = true;
						}
						// Push away — accumulate, don't ease toward target
						const t = 1 - dist / REPEL_RADIUS;
						const force = t * t * REPEL_FORCE;
						s.x += (dx / dist) * force;
						s.y += (dy / dist) * force;
					} else {
						// Ease offset back toward 0
						s.x += (0 - s.x) * RETURN_EASE;
						s.y += (0 - s.y) * RETURN_EASE;

						// Resume drift once nearly settled
						if (s.paused && Math.abs(s.x) < 2 && Math.abs(s.y) < 2) {
							blob.style.animationPlayState = '';
							s.paused = false;
						}
					}

					blob.style.translate = `${s.x}px ${s.y}px`;
				});

				// Stop loop when everything is settled and mouse gone
				if (!active && state.every(s =>
					!s.paused && Math.abs(s.x) < 0.5 && Math.abs(s.y) < 0.5
				)) {
					blobs.forEach(b => { b.style.translate = ''; });
					state.forEach(s => { s.x = 0; s.y = 0; });
					rafId = null;
					return;
				}

				rafId = requestAnimationFrame(tick);
			}

			function startIfNeeded() {
				if (!rafId) { rafId = requestAnimationFrame(tick); }
			}

			document.addEventListener('mousemove', (e) => {
				mouseX = e.clientX; mouseY = e.clientY;
				active = true;
				startIfNeeded();
			}, { passive: true });

			document.addEventListener('mouseleave', () => { active = false; });

			document.addEventListener('touchmove', (e) => {
				if (e.touches.length > 0) {
					mouseX = e.touches[0].clientX;
					mouseY = e.touches[0].clientY;
					active = true;
					startIfNeeded();
				}
			}, { passive: true });

			document.addEventListener('touchend', () => { active = false; });
		})();

	</script>
</Layout>
