---
import '../styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Jason Green — Coming Soon</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500&family=Dancing+Script:wght@400;500&display=swap" rel="stylesheet" />
	</head>
	<body class="bg-white min-h-screen overflow-hidden relative flex items-center justify-center">
		<!-- Soft pastel gradient blobs -->
		<div class="blob blob-pink"></div>
		<div class="blob blob-green"></div>
		<div class="blob blob-blue"></div>
		<div class="blob blob-yellow"></div>

		<!-- Content -->
		<main class="relative z-10 text-center px-6 max-w-3xl mx-auto">
			<p class="font-script text-lg md:text-xl text-gray-500 mb-4 tracking-wide">
				Something new is on the way
			</p>

			<h1 class="font-serif text-6xl md:text-8xl lg:text-9xl font-normal text-gray-900 leading-[0.95] mb-8">
				coming<br />soon
			</h1>

			<p class="font-sans text-base md:text-lg text-gray-500 max-w-md mx-auto leading-relaxed mb-10">
				A personal brand website by Jason Green — currently under construction. Check back soon.
			</p>

			<!-- Password gate -->
			<form id="preview-gate" class="mb-12 max-w-xs mx-auto">
				<label for="preview-password" class="sr-only">Preview password</label>
				<div class="flex items-stretch gap-2">
					<input
						id="preview-password"
						type="password"
						placeholder="Enter preview password"
						autocomplete="off"
						class="flex-1 px-4 py-2.5 rounded-full border border-gray-200 bg-white/80 text-sm text-gray-700 placeholder-gray-400 focus:outline-none focus:border-gray-400 focus:ring-1 focus:ring-gray-300 font-sans transition-colors"
					/>
					<button
						type="submit"
						class="px-5 py-2.5 bg-gray-900 text-white text-sm font-medium rounded-full hover:bg-gray-700 transition-colors"
					>
						Go
					</button>
				</div>
				<p id="gate-error" class="text-xs text-red-400 mt-2 hidden font-sans">
					Incorrect password. Try again.
				</p>
			</form>

			<div class="flex items-center justify-center gap-6 text-gray-400">
				<a href="https://github.com/CrowdTypical" aria-label="GitHub" class="hover:text-gray-900 transition-colors">
					<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
				</a>
				<a href="mailto:contact@jasongreen.biz" aria-label="Email" class="hover:text-gray-900 transition-colors">
					<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" /></svg>
				</a>
			</div>
		</main>

		<!-- Scroll hint -->
		<div class="absolute bottom-8 right-8 z-10">
			<p class="font-sans text-xs text-gray-300 tracking-widest uppercase writing-vertical">Scroll</p>
		</div>
	</body>
</html>

<script>
	// SHA-256 hash check — the password hash is stored, not the plaintext.
	// This is client-side only, so the /preview page is technically accessible
	// by URL, but the password gate keeps casual visitors out.
	async function sha256(message: string): Promise<string> {
		const msgBuffer = new TextEncoder().encode(message);
		const hashBuffer = await crypto.subtle.digest('SHA-256', msgBuffer);
		const hashArray = Array.from(new Uint8Array(hashBuffer));
		return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
	}

	// SHA-256 of the password "preview" — change the password by updating this hash
	// To generate a new hash: console.log(await sha256('your-password'))
	const EXPECTED_HASH = '5975cf1bba432391c94667f5886225f69377c0aa8b9fa21fddfb21c89bcf9092';

	const form = document.getElementById('preview-gate') as HTMLFormElement;
	const input = document.getElementById('preview-password') as HTMLInputElement;
	const error = document.getElementById('gate-error') as HTMLElement;

	form?.addEventListener('submit', async (e) => {
		e.preventDefault();
		const value = input?.value?.trim();
		if (!value) return;

		const hash = await sha256(value);
		if (hash === EXPECTED_HASH) {
			window.location.href = '/preview';
		} else {
			error?.classList.remove('hidden');
			input?.classList.add('border-red-300');
			setTimeout(() => {
				error?.classList.add('hidden');
				input?.classList.remove('border-red-300');
			}, 3000);
		}
	});
</script>

<style>
	.font-serif {
		font-family: 'Playfair Display', Georgia, serif;
	}
	.font-sans {
		font-family: 'Inter', system-ui, sans-serif;
	}
	.font-script {
		font-family: 'Dancing Script', cursive;
	}
	.writing-vertical {
		writing-mode: vertical-rl;
	}
	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border-width: 0;
	}

	/* Soft pastel gradient blobs */
	.blob {
		position: absolute;
		border-radius: 50%;
		filter: blur(80px);
		opacity: 0.5;
		animation: float 20s ease-in-out infinite;
	}
	.blob-pink {
		width: 340px;
		height: 340px;
		background: radial-gradient(circle, #f0b4f0, #f5d0f5);
		top: -5%;
		right: 25%;
		animation-delay: 0s;
	}
	.blob-green {
		width: 280px;
		height: 280px;
		background: radial-gradient(circle, #b8e6c8, #d4f0dc);
		top: 20%;
		left: 8%;
		animation-delay: -5s;
	}
	.blob-blue {
		width: 240px;
		height: 240px;
		background: radial-gradient(circle, #b8dff0, #d0ecf8);
		top: 5%;
		right: 5%;
		animation-delay: -10s;
	}
	.blob-yellow {
		width: 320px;
		height: 320px;
		background: radial-gradient(circle, #f5e6a0, #faf0c8);
		bottom: -5%;
		right: 15%;
		animation-delay: -15s;
	}

	@keyframes float {
		0%, 100% { transform: translate(0, 0) scale(1); }
		25% { transform: translate(30px, -20px) scale(1.05); }
		50% { transform: translate(-20px, 15px) scale(0.95); }
		75% { transform: translate(15px, 25px) scale(1.02); }
	}
</style>
