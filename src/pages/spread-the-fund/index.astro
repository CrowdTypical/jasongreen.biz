---
import StfLayout from '../../layouts/StfLayout.astro';
---

<StfLayout title="SPREAD THE FUNDS — Split Bills in Real-Time" variant="page">
  <style>
    :root {
      --stf-surface-deep: #0d1117;
      --stf-text-hint: #455566;
      --stf-negative: #ff4c5e;
      --stf-success: #4caf50;
      --stf-amber: #ffa726;
      --stf-danger: #ef5350;
    }
    .stf-gradient-text {
      background: linear-gradient(90deg, #00e5cc, #42a5f5);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .stf-nav-link {
      color: #8899aa;
    }
    .stf-nav-link:hover {
      color: #00e5cc;
    }
    .stf-btn-primary {
      background: #00e5cc;
      color: #0a0e14;
    }
    .stf-btn-primary:hover {
      opacity: 0.85;
    }
    .stf-btn-outline {
      color: #8899aa;
      border-color: #1e2a35;
    }
    .stf-btn-outline:hover {
      border-color: #00e5cc;
      color: #00e5cc;
    }
    .stf-card {
      background: #141a22;
      border-color: #1e2a35;
    }
    .stf-card:hover {
      border-color: #00e5cc;
    }
    .stf-footer-link {
      color: #556677;
    }
    .stf-footer-link:hover {
      color: #00e5cc;
    }

    /* Screenshot fan gallery */
    .screenshot-fan {
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      height: 380px;
      perspective: 1200px;
      padding: 0 40px;
    }
    @media (min-width: 768px) {
      .screenshot-fan {
        height: 460px;
      }
    }
    @media (min-width: 1024px) {
      .screenshot-fan {
        height: 520px;
      }
    }
    .screenshot-fan-card {
      position: absolute;
      width: 150px;
      height: 300px;
      border: 1px solid var(--stf-border);
      overflow: hidden;
      background: var(--stf-surface);
      transition:
        transform 0.7s cubic-bezier(0.22, 0.61, 0.36, 1),
        box-shadow 0.5s ease,
        border-color 0.4s ease;
      will-change: transform;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
      cursor: pointer;
    }
    /* Water-like float: each card gets its own rhythm via nth-child */
    .screenshot-fan-card:nth-child(1) {
      animation: waterFloat1 5.2s ease-in-out infinite;
    }
    .screenshot-fan-card:nth-child(2) {
      animation: waterFloat2 6s ease-in-out infinite;
    }
    .screenshot-fan-card:nth-child(3) {
      animation: waterFloat3 4.8s ease-in-out infinite;
    }
    .screenshot-fan-card:nth-child(4) {
      animation: waterFloat1 5.5s ease-in-out infinite;
    }
    .screenshot-fan-card:nth-child(5) {
      animation: waterFloat3 5.8s ease-in-out infinite;
    }
    .screenshot-fan-card:nth-child(6) {
      animation: waterFloat2 4.6s ease-in-out infinite;
    }
    .screenshot-fan-card:nth-child(7) {
      animation: waterFloat1 6.2s ease-in-out infinite;
    }

    @keyframes waterFloat1 {
      0% {
        translate: 0 0;
        rotate: 0deg;
      }
      25% {
        translate: 2.7px -7.2px;
        rotate: 0.72deg;
      }
      50% {
        translate: -1.8px -3.6px;
        rotate: -0.45deg;
      }
      75% {
        translate: 3.6px -9px;
        rotate: 0.54deg;
      }
      100% {
        translate: 0 0;
        rotate: 0deg;
      }
    }
    @keyframes waterFloat2 {
      0% {
        translate: 0 0;
        rotate: 0deg;
      }
      30% {
        translate: -3.6px -8.1px;
        rotate: -0.63deg;
      }
      60% {
        translate: 1.8px -4.5px;
        rotate: 0.81deg;
      }
      80% {
        translate: -2.7px -9.9px;
        rotate: -0.36deg;
      }
      100% {
        translate: 0 0;
        rotate: 0deg;
      }
    }
    @keyframes waterFloat3 {
      0% {
        translate: 0 0;
        rotate: 0deg;
      }
      20% {
        translate: 1.8px -6.3px;
        rotate: 0.54deg;
      }
      45% {
        translate: -2.7px -9.9px;
        rotate: -0.72deg;
      }
      70% {
        translate: 3.6px -4.5px;
        rotate: 0.36deg;
      }
      100% {
        translate: 0 0;
        rotate: 0deg;
      }
    }
    .screenshot-fan-card:hover {
      box-shadow:
        0 12px 48px rgba(0, 229, 204, 0.15),
        0 8px 32px rgba(0, 0, 0, 0.5);
      border-color: rgba(0, 229, 204, 0.3);
    }
    .screenshot-fan-card.expanded {
      z-index: 100 !important;
      box-shadow:
        0 20px 60px rgba(0, 229, 204, 0.2),
        0 12px 40px rgba(0, 0, 0, 0.6);
      border-color: var(--stf-primary);
    }
    /* Lightbox overlay */
    .screenshot-lightbox {
      position: fixed;
      inset: 0;
      z-index: 9999;
      background: rgba(10, 14, 20, 0);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      pointer-events: none;
      transition: background 0.4s ease;
    }
    .screenshot-lightbox.open {
      background: rgba(10, 14, 20, 0.92);
      pointer-events: auto;
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
    }
    .screenshot-lightbox img {
      max-height: 90vh;
      max-width: 90vw;
      object-fit: contain;
      border: 1px solid var(--stf-primary);
      box-shadow:
        0 20px 80px rgba(0, 229, 204, 0.15),
        0 0 0 1px rgba(0, 229, 204, 0.3);
      transition: transform 0.45s cubic-bezier(0.22, 0.61, 0.36, 1);
      position: absolute;
      visibility: hidden;
    }
    .screenshot-lightbox.open img {
      visibility: visible;
    }
    @media (min-width: 768px) {
      .screenshot-fan-card {
        width: 190px;
        height: 380px;
      }
    }
    @media (min-width: 1024px) {
      .screenshot-fan-card {
        width: 220px;
        height: 440px;
      }
    }
    .screenshot-fan-card img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: top;
      display: block;
      pointer-events: none;
    }
  </style>

  <div class="min-h-screen">
    <!-- Nav -->
    <nav
      class="fixed top-0 left-0 right-0 z-50 border-b"
      style="background: var(--stf-surface-alt); border-color: var(--stf-border);"
    >
      <div
        class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between"
      >
        <a href="/spread-the-fund" class="flex items-center gap-3">
          <img
            src="/spread-the-fund/glitch_dollar_icon.png"
            alt="Spread the Funds"
            class="w-7 h-7"
          />
          <span
            class="text-sm font-bold uppercase tracking-[4px]"
            style="color: var(--stf-text);">SPREAD THE FUNDS</span
          >
        </a>
        <div class="flex items-center gap-6">
          <a
            href="#features"
            class="hidden sm:inline text-xs font-bold uppercase tracking-[2px] stf-nav-link transition-colors"
            >FEATURES</a
          >
          <a
            href="#how-it-works"
            class="hidden sm:inline text-xs font-bold uppercase tracking-[2px] stf-nav-link transition-colors"
            >HOW IT WORKS</a
          >
          <a
            href="#legal"
            class="hidden sm:inline text-xs font-bold uppercase tracking-[2px] stf-nav-link transition-colors"
            >LEGAL</a
          >
          <a
            href="/"
            class="page-transition-left text-xs font-bold uppercase tracking-[2px] transition-colors"
            style="color: var(--stf-text-dim);"
          >
            &larr; PORTFOLIO
          </a>
        </div>
      </div>
    </nav>

    <!-- Hero -->
    <section
      class="relative min-h-[80vh] flex items-center justify-center pt-16"
      style="background: var(--stf-bg);"
    >
      <div class="relative z-10 text-center px-6 max-w-3xl mx-auto">
        <div class="flex justify-center mb-8">
          <img
            src="/spread-the-fund/glitch_dollar_icon.png"
            alt="Spread the Funds icon"
            class="w-20 h-20 md:w-24 md:h-24"
          />
        </div>
        <div
          class="inline-block px-4 py-1.5 text-xs font-bold uppercase tracking-[3px] border mb-8"
          style="color: var(--stf-primary); border-color: var(--stf-primary); background: rgba(0, 229, 204, 0.08);"
        >
          ANDROID APP
        </div>
        <h1
          class="text-3xl md:text-5xl lg:text-6xl font-bold uppercase tracking-[4px] leading-tight mb-6"
        >
          <span class="stf-gradient-text">SPREAD THE FUNDS</span>
        </h1>
        <p
          class="text-base md:text-lg uppercase tracking-[3px] font-bold mb-4"
          style="color: var(--stf-text-secondary);"
        >
          SPLIT BILLS IN REAL-TIME
        </p>
        <p
          class="text-sm md:text-base leading-relaxed max-w-lg mx-auto mb-10"
          style="color: var(--stf-text-dim);"
        >
          A bill-splitting app with real-time updates between users. Create
          groups, add bills, adjust splits, and settle up — all synced instantly
          via Firebase.
        </p>
        <div
          class="flex flex-col sm:flex-row items-center justify-center gap-4"
        >
          <a
            href="#features"
            class="px-8 py-3 font-bold text-xs uppercase tracking-[2px] stf-btn-primary transition-opacity"
          >
            SEE FEATURES
          </a>
          <a
            href="https://play.google.com/store/apps/details?id=biz.jasongreen.spreadthefund"
            target="_blank"
            rel="noopener noreferrer"
            class="px-8 py-3 font-bold text-xs uppercase tracking-[2px] border stf-btn-outline transition-colors hidden"
            id="play-store-btn"
          >
            GET ON GOOGLE PLAY
          </a>
        </div>
      </div>
    </section>

    <!-- App Screenshots -->
    <section
      class="py-10 md:py-14 overflow-hidden"
      style="background: var(--stf-surface-deep);"
    >
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-6 md:mb-8 px-6">
          <p
            class="text-xs font-bold uppercase tracking-[3px] mb-3"
            style="color: var(--stf-primary);"
          >
            APP PREVIEW
          </p>
          <h2
            class="text-2xl md:text-3xl font-bold uppercase tracking-[4px]"
            style="color: var(--stf-text);"
          >
            SEE IT IN ACTION
          </h2>
        </div>

        <!-- Fan layout -->
        <div class="screenshot-fan" id="screenshot-fan">
          <div class="screenshot-fan-card" data-fan="0">
            <img
              src="/spread-the-fund/screenshots/new-group.jpg"
              alt="New Group"
              loading="lazy"
            />
          </div>
          <div class="screenshot-fan-card" data-fan="1">
            <img
              src="/spread-the-fund/screenshots/add-partner.jpg"
              alt="Add Partner"
              loading="lazy"
            />
          </div>
          <div class="screenshot-fan-card" data-fan="2">
            <img
              src="/spread-the-fund/screenshots/groups.jpg"
              alt="Groups Dashboard"
              loading="lazy"
            />
          </div>
          <div class="screenshot-fan-card" data-fan="3">
            <img
              src="/spread-the-fund/screenshots/login.jpg"
              alt="Login Screen"
              loading="lazy"
            />
          </div>
          <div class="screenshot-fan-card" data-fan="4">
            <img
              src="/spread-the-fund/screenshots/group-activity.jpg"
              alt="Group Activity"
              loading="lazy"
            />
          </div>
          <div class="screenshot-fan-card" data-fan="5">
            <img
              src="/spread-the-fund/screenshots/bill-edit.jpg"
              alt="Bill Edit"
              loading="lazy"
            />
          </div>
          <div class="screenshot-fan-card" data-fan="6">
            <img
              src="/spread-the-fund/screenshots/group-details.jpg"
              alt="Group Details"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Lightbox -->
    <div class="screenshot-lightbox" id="screenshot-lightbox">
      <img src="" alt="Screenshot preview" id="lightbox-img" />
    </div>

    <!-- Features -->
    <section
      id="features"
      class="py-16 md:py-20 px-6 md:px-16"
      style="background: var(--stf-bg);"
    >
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-12">
          <p
            class="text-xs font-bold uppercase tracking-[3px] mb-3"
            style="color: var(--stf-primary);"
          >
            FEATURES
          </p>
          <h2
            class="text-2xl md:text-3xl font-bold uppercase tracking-[4px]"
            style="color: var(--stf-text);"
          >
            EVERYTHING YOU NEED
          </h2>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          <div class="p-6 border stf-card">
            <div
              class="w-10 h-10 flex items-center justify-center mb-4 border"
              style="border-color: var(--stf-primary); background: rgba(0, 229, 204, 0.08);"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" class="w-5 h-5"><path d="M12 4V1L8 5l4 4V6c3.31 0 6 2.69 6 6 0 1.01-.25 1.97-.7 2.8l1.46 1.46C19.54 15.03 20 13.57 20 12c0-4.42-3.58-8-8-8zm0 14c-3.31 0-6-2.69-6-6 0-1.01.25-1.97.7-2.8L5.24 7.74C4.46 8.97 4 10.43 4 12c0 4.42 3.58 8 8 8v3l4-4-4-4v3z"/></svg>
            </div>
            <h3
              class="text-xs font-bold uppercase tracking-[2px] mb-2"
              style="color: var(--stf-text);"
            >
              REAL-TIME SYNC
            </h3>
            <p
              class="text-[13px] leading-relaxed"
              style="color: var(--stf-text-dim);"
            >
              Bills sync instantly between all group members via Firebase.
              Everyone sees updates the moment they happen.
            </p>
          </div>

          <div class="p-6 border stf-card">
            <div
              class="w-10 h-10 flex items-center justify-center mb-4 border"
              style="border-color: var(--stf-primary); background: rgba(0, 229, 204, 0.08);"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" class="w-5 h-5"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>
            </div>
            <h3
              class="text-xs font-bold uppercase tracking-[2px] mb-2"
              style="color: var(--stf-text);"
            >
              MULTIPLE GROUPS
            </h3>
            <p
              class="text-[13px] leading-relaxed"
              style="color: var(--stf-text-dim);"
            >
              Create separate groups for housemates, trips, couples, or any
              situation. Keep your bills organized.
            </p>
          </div>

          <div class="p-6 border stf-card">
            <div
              class="w-10 h-10 flex items-center justify-center mb-4 border"
              style="border-color: var(--stf-primary); background: rgba(0, 229, 204, 0.08);"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" class="w-5 h-5"><path d="M12 2C6.49 2 2 6.49 2 12s4.49 10 10 10c1.38 0 2.5-1.12 2.5-2.5 0-.61-.23-1.2-.64-1.67-.08-.1-.13-.21-.13-.33 0-.28.22-.5.5-.5H16c3.31 0 6-2.69 6-6 0-4.96-4.49-9-10-9zm-5.5 9c-.83 0-1.5-.67-1.5-1.5S5.67 8 6.5 8 8 8.67 8 9.5 7.33 11 6.5 11zm3-4C8.67 7 8 6.33 8 5.5S8.67 4 9.5 4s1.5.67 1.5 1.5S10.33 7 9.5 7zm5 0c-.83 0-1.5-.67-1.5-1.5S13.67 4 14.5 4s1.5.67 1.5 1.5S15.33 7 14.5 7zm3 4c-.83 0-1.5-.67-1.5-1.5S16.67 8 17.5 8s1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/></svg>
            </div>
            <h3
              class="text-xs font-bold uppercase tracking-[2px] mb-2"
              style="color: var(--stf-text);"
            >
              CUSTOM COLOURS
            </h3>
            <p
              class="text-[13px] leading-relaxed"
              style="color: var(--stf-text-dim);"
            >
              12 accent colours to personalise each group. Make it yours.
            </p>
          </div>

          <div class="p-6 border stf-card">
            <div
              class="w-10 h-10 flex items-center justify-center mb-4 border"
              style="border-color: var(--stf-primary); background: rgba(0, 229, 204, 0.08);"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" class="w-5 h-5"><path d="M3 17v2h6v-2H3zM3 5v2h10V5H3zm10 16v-2h8v-2h-8v-2h-2v6h2zM7 9v2H3v2h4v2h2V9H7zm14 4v-2H11v2h10zm-6-4h2V7h4V5h-4V3h-2v6z"/></svg>
            </div>
            <h3
              class="text-xs font-bold uppercase tracking-[2px] mb-2"
              style="color: var(--stf-text);"
            >
              SMART SPLIT SLIDER
            </h3>
            <p
              class="text-[13px] leading-relaxed"
              style="color: var(--stf-text-dim);"
            >
              Adjust the split percentage with an intuitive slider. No more
              manual math.
            </p>
          </div>

          <div class="p-6 border stf-card">
            <div
              class="w-10 h-10 flex items-center justify-center mb-4 border"
              style="border-color: var(--stf-primary); background: rgba(0, 229, 204, 0.08);"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" class="w-5 h-5"><path d="M22 5.18L10.59 16.6l-4.24-4.24 1.41-1.41 2.83 2.83 10-10L22 5.18zm-2.21 5.04c.13.57.21 1.17.21 1.78 0 4.42-3.58 8-8 8s-8-3.58-8-8 3.58-8 8-8c1.58 0 3.04.46 4.28 1.25l1.44-1.44C16.1 2.67 14.13 2 12 2 6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10c0-1.19-.22-2.33-.6-3.39l-1.61 1.61z"/></svg>
            </div>
            <h3
              class="text-xs font-bold uppercase tracking-[2px] mb-2"
              style="color: var(--stf-text);"
            >
              SETTLEMENT TRACKING
            </h3>
            <p
              class="text-[13px] leading-relaxed"
              style="color: var(--stf-text-dim);"
            >
              Record payments and track who owes whom. Mark debts as settled and
              keep a clean ledger.
            </p>
          </div>

          <div class="p-6 border stf-card">
            <div
              class="w-10 h-10 flex items-center justify-center mb-4 border"
              style="border-color: var(--stf-primary); background: rgba(0, 229, 204, 0.08);"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" class="w-5 h-5"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/></svg>
            </div>
            <h3
              class="text-xs font-bold uppercase tracking-[2px] mb-2"
              style="color: var(--stf-text);"
            >
              PRIVACY FIRST
            </h3>
            <p
              class="text-[13px] leading-relaxed"
              style="color: var(--stf-text-dim);"
            >
              No analytics, no ads, no tracking. Your data stays yours. Delete
              everything at any time.
            </p>
          </div>
        </div>

        <!-- Additional features -->
        <div class="mt-12 grid sm:grid-cols-2 gap-3">
          <div
            class="flex items-center gap-3 p-3 border"
            style="background: var(--stf-surface-deep); border-color: var(--stf-border);"
          >
            <span style="color: var(--stf-primary);">›</span>
            <span
              class="text-xs font-bold uppercase tracking-[1px]"
              style="color: var(--stf-text-secondary);">GOOGLE SIGN-IN</span
            >
          </div>
          <div
            class="flex items-center gap-3 p-3 border"
            style="background: var(--stf-surface-deep); border-color: var(--stf-border);"
          >
            <span style="color: var(--stf-primary);">›</span>
            <span
              class="text-xs font-bold uppercase tracking-[1px]"
              style="color: var(--stf-text-secondary);">CATEGORY ICONS</span
            >
          </div>
          <div
            class="flex items-center gap-3 p-3 border"
            style="background: var(--stf-surface-deep); border-color: var(--stf-border);"
          >
            <span style="color: var(--stf-primary);">›</span>
            <span
              class="text-xs font-bold uppercase tracking-[1px]"
              style="color: var(--stf-text-secondary);">BILL NOTES</span
            >
          </div>
          <div
            class="flex items-center gap-3 p-3 border"
            style="background: var(--stf-surface-deep); border-color: var(--stf-border);"
          >
            <span style="color: var(--stf-primary);">›</span>
            <span
              class="text-xs font-bold uppercase tracking-[1px]"
              style="color: var(--stf-text-secondary);">EMAIL INVITATIONS</span
            >
          </div>
