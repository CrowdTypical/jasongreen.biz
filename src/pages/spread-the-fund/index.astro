---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Spread the Fund — Collaborative Fund Management">
	<!-- Simple nav for this standalone page -->
	<nav class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md border-b border-gray-100">
		<div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
			<a href="/spread-the-fund" class="font-serif text-xl font-bold text-gray-900 hover:text-gray-700 transition-colors">
				Spread the Fund
			</a>
			<div class="flex items-center gap-6">
				<a href="#features" class="hidden sm:inline text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">Features</a>
				<a href="#how-it-works" class="hidden sm:inline text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">How It Works</a>
				<a href="#legal" class="hidden sm:inline text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">Legal</a>
				<a href="/preview" class="text-sm font-medium text-gray-500 hover:text-gray-900 transition-colors">
					&larr; Portfolio
				</a>
			</div>
		</div>
	</nav>

	<!-- Hero -->
	<section class="relative min-h-[80vh] flex items-center justify-center bg-gradient-to-br from-emerald-50 via-white to-teal-50 pt-20">
		<div class="relative z-10 text-center px-6 max-w-3xl mx-auto">
			<span class="inline-block px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-emerald-700 bg-emerald-100 rounded-full mb-6">
				Coming Soon
			</span>
			<h1 class="font-serif text-4xl md:text-6xl lg:text-7xl font-bold text-gray-900 leading-tight mb-6">
				Fund Together.<br />Grow Together.
			</h1>
			<p class="font-sans text-lg md:text-xl text-gray-500 max-w-xl mx-auto leading-relaxed mb-10">
				Spread the Fund makes it easy to create, manage, and contribute to shared funds with the people who matter most.
			</p>
			<div class="flex flex-col sm:flex-row items-center justify-center gap-4">
				<a href="#features" class="px-8 py-3 bg-emerald-600 text-white rounded-full font-medium text-sm hover:bg-emerald-700 transition-colors">
					See Features
				</a>
				<a href="#how-it-works" class="px-8 py-3 border border-gray-300 text-gray-700 rounded-full font-medium text-sm hover:border-emerald-600 hover:text-emerald-700 transition-colors">
					How It Works
				</a>
			</div>
		</div>

		<!-- Decorative circles -->
		<div class="absolute top-20 left-10 w-64 h-64 bg-emerald-100 rounded-full opacity-30 blur-3xl"></div>
		<div class="absolute bottom-10 right-10 w-80 h-80 bg-teal-100 rounded-full opacity-30 blur-3xl"></div>
	</section>

	<!-- App Demo / Preview -->
	<section class="py-20 md:py-28 px-6 md:px-16 bg-white">
		<div class="max-w-5xl mx-auto">
			<div class="text-center mb-16">
				<p class="text-sm font-semibold uppercase tracking-wider text-emerald-600 mb-2">App Preview</p>
				<h2 class="font-serif text-3xl md:text-4xl font-bold text-gray-900">See It In Action</h2>
			</div>

			<!-- Mock app screens -->
			<div class="grid md:grid-cols-3 gap-8">
				<!-- Screen 1: Dashboard -->
				<div class="rounded-2xl border border-gray-200 bg-gray-50 overflow-hidden shadow-sm">
					<div class="bg-emerald-600 px-4 py-3 flex items-center gap-2">
						<div class="w-3 h-3 rounded-full bg-white/30"></div>
						<div class="w-3 h-3 rounded-full bg-white/30"></div>
						<div class="w-3 h-3 rounded-full bg-white/30"></div>
						<span class="text-white text-xs font-medium ml-2">Dashboard</span>
					</div>
					<div class="p-5 space-y-3">
						<div class="bg-white rounded-lg p-3 border border-gray-100">
							<p class="text-xs text-gray-400 mb-1">Total Balance</p>
							<p class="text-2xl font-bold text-gray-900">$2,450.00</p>
						</div>
						<div class="bg-white rounded-lg p-3 border border-gray-100 flex items-center justify-between">
							<div>
								<p class="text-sm font-medium text-gray-900">Vacation Fund</p>
								<p class="text-xs text-gray-400">4 members</p>
							</div>
							<span class="text-sm font-semibold text-emerald-600">$1,200</span>
						</div>
						<div class="bg-white rounded-lg p-3 border border-gray-100 flex items-center justify-between">
							<div>
								<p class="text-sm font-medium text-gray-900">Emergency Fund</p>
								<p class="text-xs text-gray-400">2 members</p>
							</div>
							<span class="text-sm font-semibold text-emerald-600">$850</span>
						</div>
						<div class="bg-white rounded-lg p-3 border border-gray-100 flex items-center justify-between">
							<div>
								<p class="text-sm font-medium text-gray-900">Birthday Gift</p>
								<p class="text-xs text-gray-400">6 members</p>
							</div>
							<span class="text-sm font-semibold text-emerald-600">$400</span>
						</div>
					</div>
				</div>

				<!-- Screen 2: Fund Detail -->
				<div class="rounded-2xl border border-gray-200 bg-gray-50 overflow-hidden shadow-sm">
					<div class="bg-emerald-600 px-4 py-3 flex items-center gap-2">
						<div class="w-3 h-3 rounded-full bg-white/30"></div>
						<div class="w-3 h-3 rounded-full bg-white/30"></div>
						<div class="w-3 h-3 rounded-full bg-white/30"></div>
						<span class="text-white text-xs font-medium ml-2">Fund Detail</span>
					</div>
					<div class="p-5 space-y-4">
						<div class="text-center">
							<p class="text-sm font-medium text-gray-900 mb-1">Vacation Fund</p>
							<div class="w-full bg-gray-200 rounded-full h-2.5 mb-2">
								<div class="bg-emerald-500 h-2.5 rounded-full" style="width: 60%"></div>
							</div>
							<p class="text-xs text-gray-400">$1,200 of $2,000 goal</p>
						</div>
						<div class="space-y-2">
							<p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Recent Activity</p>
							<div class="flex items-center gap-3 bg-white rounded-lg p-2.5 border border-gray-100">
								<div class="w-8 h-8 rounded-full bg-emerald-100 flex items-center justify-center text-xs font-bold text-emerald-700">JG</div>
								<div class="flex-1">
									<p class="text-xs font-medium text-gray-900">Jason contributed</p>
									<p class="text-xs text-gray-400">2 hours ago</p>
								</div>
								<span class="text-xs font-semibold text-emerald-600">+$50</span>
							</div>
							<div class="flex items-center gap-3 bg-white rounded-lg p-2.5 border border-gray-100">
								<div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center text-xs font-bold text-blue-700">AK</div>
								<div class="flex-1">
									<p class="text-xs font-medium text-gray-900">Alex contributed</p>
									<p class="text-xs text-gray-400">1 day ago</p>
								</div>
								<span class="text-xs font-semibold text-emerald-600">+$100</span>
							</div>
							<div class="flex items-center gap-3 bg-white rounded-lg p-2.5 border border-gray-100">
								<div class="w-8 h-8 rounded-full bg-purple-100 flex items-center justify-center text-xs font-bold text-purple-700">SM</div>
								<div class="flex-1">
									<p class="text-xs font-medium text-gray-900">Sara contributed</p>
									<p class="text-xs text-gray-400">3 days ago</p>
								</div>
								<span class="text-xs font-semibold text-emerald-600">+$75</span>
							</div>
						</div>
					</div>
				</div>

				<!-- Screen 3: Create Fund -->
				<div class="rounded-2xl border border-gray-200 bg-gray-50 overflow-hidden shadow-sm">
					<div class="bg-emerald-600 px-4 py-3 flex items-center gap-2">
						<div class="w-3 h-3 rounded-full bg-white/30"></div>
						<div class="w-3 h-3 rounded-full bg-white/30"></div>
						<div class="w-3 h-3 rounded-full bg-white/30"></div>
						<span class="text-white text-xs font-medium ml-2">Create Fund</span>
					</div>
					<div class="p-5 space-y-4">
						<div>
							<label class="block text-xs font-medium text-gray-500 mb-1">Fund Name</label>
							<div class="bg-white border border-gray-200 rounded-lg px-3 py-2 text-sm text-gray-900">Weekend Getaway</div>
						</div>
						<div>
							<label class="block text-xs font-medium text-gray-500 mb-1">Goal Amount</label>
							<div class="bg-white border border-gray-200 rounded-lg px-3 py-2 text-sm text-gray-900">$3,000</div>
						</div>
						<div>
							<label class="block text-xs font-medium text-gray-500 mb-1">Description</label>
							<div class="bg-white border border-gray-200 rounded-lg px-3 py-2 text-sm text-gray-400 h-16">A fund for our annual trip...</div>
						</div>
						<div>
							<label class="block text-xs font-medium text-gray-500 mb-1">Invite Members</label>
							<div class="flex gap-2">
								<div class="w-8 h-8 rounded-full bg-emerald-100 flex items-center justify-center text-xs font-bold text-emerald-700">+</div>
								<div class="w-8 h-8 rounded-full bg-gray-200 flex items-center justify-center text-xs font-bold text-gray-500">AK</div>
								<div class="w-8 h-8 rounded-full bg-gray-200 flex items-center justify-center text-xs font-bold text-gray-500">SM</div>
							</div>
						</div>
						<button class="w-full py-2.5 bg-emerald-600 text-white text-sm font-medium rounded-lg">Create Fund</button>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Features -->
	<section id="features" class="py-20 md:py-28 px-6 md:px-16 bg-gray-50">
		<div class="max-w-5xl mx-auto">
			<div class="text-center mb-16">
				<p class="text-sm font-semibold uppercase tracking-wider text-emerald-600 mb-2">Features</p>
				<h2 class="font-serif text-3xl md:text-4xl font-bold text-gray-900">Everything You Need</h2>
			</div>

			<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
				<div class="bg-white rounded-xl p-6 border border-gray-100">
					<div class="w-10 h-10 rounded-lg bg-emerald-100 flex items-center justify-center mb-4">
						<svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
					</div>
					<h3 class="font-semibold text-gray-900 mb-2">Shared Funds</h3>
					<p class="text-sm text-gray-500 leading-relaxed">Create funds with friends, family, or groups. Everyone can contribute and track progress toward shared goals.</p>
				</div>

				<div class="bg-white rounded-xl p-6 border border-gray-100">
					<div class="w-10 h-10 rounded-lg bg-emerald-100 flex items-center justify-center mb-4">
						<svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" /></svg>
					</div>
					<h3 class="font-semibold text-gray-900 mb-2">Real-Time Tracking</h3>
					<p class="text-sm text-gray-500 leading-relaxed">See contributions as they happen. Visual progress bars and activity feeds keep everyone in the loop.</p>
				</div>

				<div class="bg-white rounded-xl p-6 border border-gray-100">
					<div class="w-10 h-10 rounded-lg bg-emerald-100 flex items-center justify-center mb-4">
						<svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" /></svg>
					</div>
					<h3 class="font-semibold text-gray-900 mb-2">Group Management</h3>
					<p class="text-sm text-gray-500 leading-relaxed">Invite members, set roles, and manage permissions. Keep your funds organized and your group engaged.</p>
				</div>

				<div class="bg-white rounded-xl p-6 border border-gray-100">
					<div class="w-10 h-10 rounded-lg bg-emerald-100 flex items-center justify-center mb-4">
						<svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" /></svg>
					</div>
					<h3 class="font-semibold text-gray-900 mb-2">Secure Transactions</h3>
					<p class="text-sm text-gray-500 leading-relaxed">Industry-standard encryption and secure payment processing keep your money and data safe.</p>
				</div>

				<div class="bg-white rounded-xl p-6 border border-gray-100">
					<div class="w-10 h-10 rounded-lg bg-emerald-100 flex items-center justify-center mb-4">
						<svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" /></svg>
					</div>
					<h3 class="font-semibold text-gray-900 mb-2">Smart Notifications</h3>
					<p class="text-sm text-gray-500 leading-relaxed">Stay informed with contribution alerts, goal milestones, and reminders. Never miss an update.</p>
				</div>

				<div class="bg-white rounded-xl p-6 border border-gray-100">
					<div class="w-10 h-10 rounded-lg bg-emerald-100 flex items-center justify-center mb-4">
						<svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6a7.5 7.5 0 1 0 7.5 7.5h-7.5V6Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5H21A7.5 7.5 0 0 0 13.5 3v7.5Z" /></svg>
					</div>
					<h3 class="font-semibold text-gray-900 mb-2">Spending Insights</h3>
					<p class="text-sm text-gray-500 leading-relaxed">Understand your fund activity with clear breakdowns, contribution history, and goal analytics.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- How It Works -->
	<section id="how-it-works" class="py-20 md:py-28 px-6 md:px-16 bg-white">
		<div class="max-w-4xl mx-auto">
			<div class="text-center mb-16">
				<p class="text-sm font-semibold uppercase tracking-wider text-emerald-600 mb-2">Simple Process</p>
				<h2 class="font-serif text-3xl md:text-4xl font-bold text-gray-900">How It Works</h2>
			</div>

			<div class="grid md:grid-cols-3 gap-12">
				<div class="text-center">
					<div class="w-14 h-14 rounded-full bg-emerald-600 text-white flex items-center justify-center text-xl font-bold mx-auto mb-5">1</div>
					<h3 class="font-semibold text-gray-900 mb-2">Create a Fund</h3>
					<p class="text-sm text-gray-500 leading-relaxed">Name your fund, set a goal, and add a description. It only takes a minute.</p>
				</div>
				<div class="text-center">
					<div class="w-14 h-14 rounded-full bg-emerald-600 text-white flex items-center justify-center text-xl font-bold mx-auto mb-5">2</div>
					<h3 class="font-semibold text-gray-900 mb-2">Invite People</h3>
					<p class="text-sm text-gray-500 leading-relaxed">Share an invite link with friends, family, or your group. Anyone can join and contribute.</p>
				</div>
				<div class="text-center">
					<div class="w-14 h-14 rounded-full bg-emerald-600 text-white flex items-center justify-center text-xl font-bold mx-auto mb-5">3</div>
					<h3 class="font-semibold text-gray-900 mb-2">Grow Together</h3>
					<p class="text-sm text-gray-500 leading-relaxed">Watch your fund grow in real time. Track contributions, hit milestones, and reach your goals.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Legal Section -->
	<section id="legal" class="py-20 md:py-28 px-6 md:px-16 bg-gray-50 border-t border-gray-100">
		<div class="max-w-3xl mx-auto text-center">
			<p class="text-sm font-semibold uppercase tracking-wider text-gray-400 mb-2">Legal</p>
			<h2 class="font-serif text-3xl md:text-4xl font-bold text-gray-900 mb-4">Legal Information</h2>
			<p class="text-gray-500 text-base leading-relaxed mb-12 max-w-lg mx-auto">
				Transparency matters. Review our policies to understand how we handle your data and define the terms of service.
			</p>

			<div class="grid sm:grid-cols-3 gap-6">
				<a href="/spread-the-fund/privacy" class="group block bg-white rounded-xl p-6 border border-gray-100 hover:border-emerald-200 hover:shadow-md transition-all">
					<svg class="w-8 h-8 text-gray-300 group-hover:text-emerald-500 transition-colors mx-auto mb-3" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" /></svg>
					<h3 class="font-semibold text-gray-900 mb-1">Privacy Policy</h3>
					<p class="text-xs text-gray-400">How we collect, use, and protect your information.</p>
				</a>

				<a href="/spread-the-fund/terms" class="group block bg-white rounded-xl p-6 border border-gray-100 hover:border-emerald-200 hover:shadow-md transition-all">
					<svg class="w-8 h-8 text-gray-300 group-hover:text-emerald-500 transition-colors mx-auto mb-3" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" /></svg>
					<h3 class="font-semibold text-gray-900 mb-1">Terms & Conditions</h3>
					<p class="text-xs text-gray-400">The rules and guidelines for using Spread the Fund.</p>
				</a>

				<a href="/spread-the-fund/copyright" class="group block bg-white rounded-xl p-6 border border-gray-100 hover:border-emerald-200 hover:shadow-md transition-all">
					<svg class="w-8 h-8 text-gray-300 group-hover:text-emerald-500 transition-colors mx-auto mb-3" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" /></svg>
					<h3 class="font-semibold text-gray-900 mb-1">Copyright</h3>
					<p class="text-xs text-gray-400">Intellectual property and usage rights information.</p>
				</a>
			</div>
		</div>
	</section>

	<!-- Footer -->
