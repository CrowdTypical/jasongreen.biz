  <script>
    // Screenshot fan layout with hover/click interactivity
    (function () {
      const fan = document.getElementById('screenshot-fan');
      const cards = document.querySelectorAll<HTMLElement>(
        '.screenshot-fan-card'
      );
      const total = cards.length;
      if (!fan || total === 0) return;

      const mid = Math.floor(total / 2);
      const rotations = [-12, -8, -4, 0, 4, 8, 12];

      // Store each card's resting transform
      type CardState = { tx: number; ty: number; rot: number; z: number };
      const restStates: CardState[] = [];

      function layoutFan() {
        const isMobile = window.innerWidth < 768;
        const spacing = isMobile ? 0.42 : 0.52;

        cards.forEach((card, i) => {
          const pos = i - mid;
          const rot = rotations[i] ?? pos * 4;
          const cardW = card.offsetWidth;
          const tx = pos * cardW * spacing;
          const ty = Math.abs(pos) * (isMobile ? 8 : 12);
          const z = total - Math.abs(pos);

          restStates[i] = { tx, ty, rot, z };

          // Stagger the float animation so cards bob at different times
          card.style.animationDelay = `${i * 0.4}s`;

          card.style.transform = `translateX(${tx}px) translateY(${ty}px) rotate(${rot}deg)`;
          card.style.zIndex = String(z);
        });
      }

      // Hover: lift card up & remove rotation
      cards.forEach((card, i) => {
        card.addEventListener('mouseenter', () => {
          const s = restStates[i];
          if (!s) return;
          card.style.transform = `translateX(${s.tx}px) translateY(${s.ty - 20}px) rotate(${s.rot * 0.3}deg) scale(1.05)`;
          card.style.zIndex = String(total + 1);
        });

        card.addEventListener('mouseleave', () => {
          const s = restStates[i];
          if (!s) return;
          card.style.transform = `translateX(${s.tx}px) translateY(${s.ty}px) rotate(${s.rot}deg)`;
          card.style.zIndex = String(s.z);
        });

        // Click: open lightbox with zoom-from-card effect
        card.addEventListener('click', (e) => {
          e.stopPropagation();
          const img = card.querySelector('img');
          if (!img) return;
          const lightbox = document.getElementById('screenshot-lightbox');
          const lightboxImg = document.getElementById(
            'lightbox-img'
          ) as HTMLImageElement;
          if (!lightbox || !lightboxImg) return;

          // Get card's position on screen
          const rect = card.getBoundingClientRect();

          // Position image exactly where the card is
          lightboxImg.src = img.src;
          lightboxImg.alt = img.alt;
          lightboxImg.style.transition = 'none';
          lightboxImg.style.left = rect.left + 'px';
          lightboxImg.style.top = rect.top + 'px';
          lightboxImg.style.width = rect.width + 'px';
          lightboxImg.style.height = rect.height + 'px';
          lightboxImg.style.maxHeight = 'none';
          lightboxImg.style.maxWidth = 'none';
          lightboxImg.style.transform = 'none';

          // Force reflow so browser paints the starting position
          lightboxImg.offsetHeight;

          // Now animate to full size centered
          const vw = window.innerWidth;
          const vh = window.innerHeight;
          const finalH = vh * 0.88;
          const aspectRatio = rect.width / rect.height;
          const finalW = finalH * aspectRatio;
          const finalLeft = (vw - finalW) / 2;
          const finalTop = (vh - finalH) / 2;

          lightboxImg.style.transition =
            'left 0.45s cubic-bezier(0.22, 0.61, 0.36, 1), top 0.45s cubic-bezier(0.22, 0.61, 0.36, 1), width 0.45s cubic-bezier(0.22, 0.61, 0.36, 1), height 0.45s cubic-bezier(0.22, 0.61, 0.36, 1)';
          lightboxImg.style.left = finalLeft + 'px';
          lightboxImg.style.top = finalTop + 'px';
          lightboxImg.style.width = finalW + 'px';
          lightboxImg.style.height = finalH + 'px';
          lightbox.classList.add('open');
        });
      });

      // Close lightbox — zoom back to nothing
      const lightbox = document.getElementById('screenshot-lightbox');
      if (lightbox) {
        lightbox.addEventListener('click', () => {
          const lbImg = document.getElementById(
            'lightbox-img'
          ) as HTMLImageElement;
          if (lbImg) {
            lbImg.style.transition =
              'left 0.35s ease-in, top 0.35s ease-in, width 0.35s ease-in, height 0.35s ease-in, opacity 0.3s ease';
            lbImg.style.opacity = '0';
            lbImg.style.width = '0';
            lbImg.style.height = '0';
            lbImg.style.left = window.innerWidth / 2 + 'px';
            lbImg.style.top = window.innerHeight / 2 + 'px';
          }
          lightbox.classList.remove('open');
          setTimeout(() => {
            if (lbImg) lbImg.style.opacity = '1';
          }, 400);
        });
      }

      layoutFan();
      window.addEventListener('resize', () => {
        layoutFan();
      });
    })();

    // Page transition handling for STF page
    document.querySelectorAll('.page-transition-left').forEach((link) => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const href = (link as HTMLAnchorElement).href;
        sessionStorage.setItem('page-transition-dir', 'left');
        document.body.classList.add('page-exit-right');
        setTimeout(() => {
          window.location.href = href;
        }, 200);
      });
    });

    document.querySelectorAll('.page-transition-right').forEach((link) => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const href = (link as HTMLAnchorElement).href;
        sessionStorage.setItem('page-transition-dir', 'right');
        document.body.classList.add('page-exit-left');
        setTimeout(() => {
          window.location.href = href;
        }, 200);
      });
    });
  </script>

