	<script>
		// Screenshot fan layout with hover/click interactivity
		(function () {
			const fan = document.getElementById('screenshot-fan');
			const cards = document.querySelectorAll<HTMLElement>('.screenshot-fan-card');
			const total = cards.length;
			if (!fan || total === 0) return;

			const mid = Math.floor(total / 2);
			const rotations = [-12, -8, -4, 0, 4, 8, 12];

			// Store each card's resting transform
			type CardState = { tx: number; ty: number; rot: number; z: number };
			const restStates: CardState[] = [];
			let expandedCard: HTMLElement | null = null;

			function layoutFan() {
				const isMobile = window.innerWidth < 768;
				const spacing = isMobile ? 0.42 : 0.52;

				cards.forEach((card, i) => {
					const pos = i - mid;
					const rot = rotations[i] ?? pos * 4;
					const cardW = card.offsetWidth;
					const tx = pos * cardW * spacing;
					const ty = Math.abs(pos) * (isMobile ? 8 : 12);
					const z = total - Math.abs(pos);

					restStates[i] = { tx, ty, rot, z };

					// Stagger the float animation so cards bob at different times
					card.style.animationDelay = `${i * 0.4}s`;

					if (card !== expandedCard) {
						card.style.transform = `translateX(${tx}px) translateY(${ty}px) rotate(${rot}deg)`;
						card.style.zIndex = String(z);
					}
				});
			}

			// Hover: lift card up & remove rotation
			cards.forEach((card, i) => {
				card.addEventListener('mouseenter', () => {
					if (card === expandedCard) return;
					const s = restStates[i];
					if (!s) return;
					card.style.transform = `translateX(${s.tx}px) translateY(${s.ty - 20}px) rotate(${s.rot * 0.3}deg) scale(1.05)`;
					card.style.zIndex = String(total + 1);
				});

				card.addEventListener('mouseleave', () => {
					if (card === expandedCard) return;
					const s = restStates[i];
					if (!s) return;
					card.style.transform = `translateX(${s.tx}px) translateY(${s.ty}px) rotate(${s.rot}deg)`;
					card.style.zIndex = String(s.z);
				});

				// Click: expand to center, larger
				card.addEventListener('click', (e) => {
					e.stopPropagation();
					if (expandedCard === card) {
						collapseCard();
						return;
					}
					collapseCard();
					expandedCard = card;
					card.classList.add('expanded');
					card.style.transform = 'translateX(0) translateY(-10px) rotate(0deg) scale(1.35)';
				});
			});

			function collapseCard() {
				if (!expandedCard) return;
				const idx = Array.from(cards).indexOf(expandedCard);
				const s = restStates[idx];
				if (s) {
					expandedCard.style.transform = `translateX(${s.tx}px) translateY(${s.ty}px) rotate(${s.rot}deg)`;
					expandedCard.style.zIndex = String(s.z);
				}
				expandedCard.classList.remove('expanded');
				expandedCard = null;
			}

			// Click outside fan to collapse
			document.addEventListener('click', () => collapseCard());

			layoutFan();
			window.addEventListener('resize', () => {
				collapseCard();
				layoutFan();
			});
		})();

		// Page transition handling for STF page
		document.querySelectorAll('.page-transition-left').forEach(link => {
			link.addEventListener('click', (e) => {
				e.preventDefault();
				const href = (link as HTMLAnchorElement).href;
				sessionStorage.setItem('page-transition-dir', 'left');
				document.body.classList.add('page-exit-right');
				setTimeout(() => { window.location.href = href; }, 200);
			});
		});

		document.querySelectorAll('.page-transition-right').forEach(link => {
			link.addEventListener('click', (e) => {
				e.preventDefault();
				const href = (link as HTMLAnchorElement).href;
				sessionStorage.setItem('page-transition-dir', 'right');
				document.body.classList.add('page-exit-left');
				setTimeout(() => { window.location.href = href; }, 200);
			});
		});
	</script>
</Layout>
