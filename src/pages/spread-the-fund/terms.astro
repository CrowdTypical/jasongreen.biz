		font-family: 'Inter', system-ui, sans-serif;
		font-size: 1.25rem;
		font-weight: 600;
		color: #111827;
		margin-top: 2rem;
		margin-bottom: 0.75rem;
	}
	.prose p {
		font-family: 'Inter', system-ui, sans-serif;
		font-size: 0.9375rem;
		line-height: 1.75;
		color: #4b5563;
		margin-bottom: 1rem;
	}
	.prose ul {
		list-style: disc;
		padding-left: 1.5rem;
		margin-bottom: 1rem;
	}
	.prose li {
		font-family: 'Inter', system-ui, sans-serif;
		font-size: 0.9375rem;
		line-height: 1.75;
		color: #4b5563;
		margin-bottom: 0.25rem;
	}
	.prose a {
		color: #2563eb;
		text-decoration: underline;
	}
