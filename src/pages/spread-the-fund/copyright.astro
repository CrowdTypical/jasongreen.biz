---
import StfLayout from '../../layouts/StfLayout.astro';
import StfBackNav from '../../components/StfBackNav.astro';
---

<StfLayout title="SPREAD THE FUNDS — Copyright">
  <StfBackNav />

    <main class="pt-24 pb-20 px-6 md:px-16">
      <div class="max-w-3xl mx-auto">
        <h1
          class="text-2xl md:text-3xl font-bold uppercase tracking-[4px] mb-2"
          style="color: var(--stf-text);"
        >
          COPYRIGHT INFORMATION
        </h1>
        <p
          class="text-xs uppercase tracking-[2px] mb-10"
          style="color: var(--stf-text-dim);"
        >
          LAST UPDATED: MARCH 27, 2026
        </p>

        <div class="prose">
          <h2>Copyright Notice</h2>
          <p>&copy; 2026 Jason Green. All rights reserved.</p>
          <p>
            Spread the Funds, including but not limited to its name, logo,
            design, user interface, graphics, icons, and all software and
            underlying source code, is the intellectual property of Jason Green.
          </p>

          <h2>Permitted Use</h2>
          <p>
            You are granted a limited, non-exclusive, non-transferable license
            to use the Spread the Funds application for its intended purpose —
            creating and participating in shared funds. This license does not
            include the right to:
          </p>
          <ul>
            <li>
              Copy, modify, or distribute the application or its source code
            </li>
            <li>
              Reverse engineer, decompile, or disassemble any part of the
              application
            </li>
            <li>
              Use the application's name, logo, or branding for any commercial
              purpose
            </li>
            <li>Create derivative works based on the application</li>
          </ul>

          <h2>User-Generated Content</h2>
          <p>
            Content you create within the Service (fund names, descriptions,
            messages) remains your intellectual property. By posting content
            through the Service, you grant us a limited license to display and
            distribute that content as necessary to operate the Service.
          </p>

          <h2>Third-Party Content</h2>
          <p>
            The Service may incorporate third-party libraries, fonts, icons, or
            services. These remain the property of their respective owners and
            are used under their respective licenses.
          </p>

          <h2>Trademarks</h2>
          <p>
            "Spread the Funds" and any associated logos are trademarks of Jason
            Green. Use of these trademarks without prior written permission is
            prohibited.
          </p>

          <h2>DMCA / Copyright Complaints</h2>
          <p>
            If you believe that content available through the Service infringes
            your copyright, please contact us with the following information:
          </p>
          <ul>
            <li>
              A description of the copyrighted work you claim has been infringed
            </li>
            <li>
              A description of where the infringing material is located within
              the Service
            </li>
            <li>
              Your contact information (name, address, email, phone number)
            </li>
            <li>
              A statement that you have a good faith belief that the use is not
              authorized
            </li>
            <li>
              A statement, under penalty of perjury, that the information is
              accurate and that you are the copyright owner or authorized to act
              on their behalf
            </li>
          </ul>

          <h2>Contact</h2>
          <p>
            For copyright inquiries, please contact
            <a
              href="mailto:spreadthefund@gmail.com"
              style="color: var(--stf-primary);">spreadthefund@gmail.com</a
            >.
          </p>
        </div>
      </div>
    </main>
</StfLayout>
