---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Page Not Found">
  <!-- Interactive floating blobs (full viewport) -->
  <div
    id="blob-bg"
    class="fixed inset-0 pointer-events-none overflow-hidden"
    style="z-index: 1;"
    aria-hidden="true"
  >
    <div class="floating-blob blob-1"></div>
    <div class="floating-blob blob-2"></div>
    <div class="floating-blob blob-3"></div>
    <div class="floating-blob blob-4"></div>
    <div class="floating-blob blob-5"></div>
  </div>

  <!-- Centered 404 content -->
  <main
    class="relative min-h-screen flex flex-col items-center justify-center text-center px-6"
    style="z-index: 2;"
  >
    <h1 class="font-serif text-8xl md:text-9xl font-bold text-slate-900 mb-4 select-none">
      404
    </h1>
    <p class="font-sans text-lg md:text-xl text-slate-600 mb-8 max-w-md">
      This page doesn't exist — but you can still push the colours around.
    </p>
    <a
      href="/"
      class="inline-block font-sans text-sm font-medium text-blue-900 border-2 border-blue-900 px-6 py-3 rounded-full hover:bg-blue-900 hover:text-white transition-colors"
    >
      Back to Home
    </a>
  </main>

  <style>
    .floating-blob {
      position: absolute;
      filter: blur(40px);
      opacity: 0.4;
      mix-blend-mode: multiply;
      will-change: transform, border-radius;
    }

    .blob-1 {
      width: 450px;
      height: 450px;
      background: #c98585;
      top: -8%;
      left: 15%;
      animation:
        drift-1 21s ease-in-out infinite,
        morph-1 17s ease-in-out infinite;
    }

    .blob-2 {
      width: 400px;
      height: 400px;
      background: #d4c86e;
      top: 5%;
      right: -3%;
      animation:
        drift-2 27s ease-in-out infinite,
        morph-2 19s ease-in-out infinite;
    }

    .blob-3 {
      width: 380px;
      height: 380px;
      background: #7fba95;
      top: 30%;
      left: -5%;
      animation:
        drift-3 24s ease-in-out infinite,
        morph-3 15s ease-in-out infinite;
    }

    .blob-4 {
      width: 500px;
      height: 500px;
      background: #7aa3c4;
      top: 50%;
      right: 10%;
      animation:
        drift-4 28s ease-in-out infinite,
        morph-4 21s ease-in-out infinite;
    }

    .blob-5 {
      width: 360px;
      height: 360px;
      background: #cc9db8;
      top: 65%;
      left: 25%;
      animation:
        drift-5 23s ease-in-out infinite,
        morph-5 18s ease-in-out infinite;
    }

    @keyframes morph-1 {
      0%,
      100% {
        border-radius: 24% 76% 72% 28% / 18% 68% 32% 82%;
      }
      20% {
        border-radius: 78% 22% 28% 72% / 62% 20% 80% 38%;
      }
      40% {
        border-radius: 18% 82% 68% 32% / 32% 74% 26% 68%;
      }
      60% {
        border-radius: 72% 28% 22% 78% / 76% 30% 70% 24%;
      }
      80% {
        border-radius: 36% 64% 78% 22% / 22% 58% 42% 78%;
      }
    }

    @keyframes morph-2 {
      0%,
      100% {
        border-radius: 76% 24% 18% 82% / 72% 22% 78% 28%;
      }
      20% {
        border-radius: 22% 78% 64% 36% / 28% 80% 20% 72%;
      }
      40% {
        border-radius: 68% 32% 82% 18% / 78% 26% 74% 22%;
      }
      60% {
        border-radius: 28% 72% 36% 64% / 20% 68% 32% 80%;
      }
      80% {
        border-radius: 82% 18% 24% 76% / 64% 36% 64% 36%;
      }
    }

    @keyframes morph-3 {
      0%,
      100% {
        border-radius: 32% 68% 26% 74% / 68% 24% 76% 32%;
      }
      25% {
        border-radius: 80% 20% 74% 26% / 18% 76% 24% 82%;
      }
      50% {
        border-radius: 20% 80% 32% 68% / 74% 28% 72% 26%;
      }
      75% {
        border-radius: 68% 32% 80% 20% / 26% 64% 36% 74%;
      }
    }

    @keyframes morph-4 {
      0%,
      100% {
        border-radius: 26% 74% 68% 32% / 42% 76% 24% 58%;
      }
      16% {
        border-radius: 80% 20% 22% 78% / 78% 18% 82% 22%;
      }
      33% {
        border-radius: 18% 82% 76% 24% / 24% 72% 28% 76%;
      }
      50% {
        border-radius: 74% 26% 32% 68% / 68% 32% 68% 32%;
      }
      66% {
        border-radius: 32% 68% 82% 18% / 20% 64% 36% 80%;
      }
      83% {
        border-radius: 64% 36% 20% 80% / 76% 24% 76% 24%;
      }
    }

    @keyframes morph-5 {
      0%,
      100% {
        border-radius: 72% 28% 22% 78% / 26% 74% 26% 74%;
      }
      20% {
        border-radius: 22% 78% 76% 24% / 80% 20% 80% 20%;
      }
      40% {
        border-radius: 78% 22% 32% 68% / 32% 68% 32% 68%;
      }
      60% {
        border-radius: 28% 72% 68% 32% / 72% 28% 72% 28%;
      }
      80% {
        border-radius: 68% 32% 24% 76% / 24% 76% 24% 76%;
      }
    }

    @keyframes drift-1 {
      0%,
      100% {
        transform: translate(0, 0) scale(1);
      }
      20% {
        transform: translate(200px, 120px) scale(1.25);
      }
      40% {
        transform: translate(50px, 260px) scale(0.8);
      }
      60% {
        transform: translate(-140px, 160px) scale(1.2);
      }
      80% {
        transform: translate(-60px, -50px) scale(0.85);
      }
    }

    @keyframes drift-2 {
      0%,
      100% {
        transform: translate(0, 0) scale(1);
      }
      20% {
        transform: translate(-180px, 100px) scale(0.82);
      }
      40% {
        transform: translate(-280px, 220px) scale(1.22);
      }
      60% {
        transform: translate(-100px, 320px) scale(0.78);
      }
      80% {
        transform: translate(80px, 140px) scale(1.15);
      }
    }

    @keyframes drift-3 {
      0%,
      100% {
        transform: translate(0, 0) scale(1);
      }
      25% {
        transform: translate(240px, -80px) scale(1.2);
      }
      50% {
        transform: translate(340px, 120px) scale(0.8);
      }
      75% {
        transform: translate(100px, 200px) scale(1.15);
      }
    }

    @keyframes drift-4 {
      0%,
      100% {
        transform: translate(0, 0) scale(1);
      }
      20% {
        transform: translate(-140px, -160px) scale(1.25);
      }
      40% {
        transform: translate(-300px, -60px) scale(0.78);
      }
      60% {
        transform: translate(-180px, 140px) scale(1.18);
      }
      80% {
        transform: translate(60px, 60px) scale(0.85);
      }
    }

    @keyframes drift-5 {
      0%,
      100% {
        transform: translate(0, 0) scale(1);
      }
      20% {
        transform: translate(100px, -200px) scale(0.82);
      }
      40% {
        transform: translate(260px, -100px) scale(1.22);
      }
      60% {
        transform: translate(180px, 80px) scale(0.8);
      }
      80% {
        transform: translate(-50px, -60px) scale(1.16);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .floating-blob {
        animation: none !important;
      }
    }
  </style>

  <script>
    (() => {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      const blobBg = document.getElementById('blob-bg');
      if (!blobBg) return;

      const blobs = blobBg.querySelectorAll<HTMLElement>('.floating-blob');
      if (blobs.length === 0) return;

      const REPEL_RADIUS = 500;
      const REPEL_FORCE = 18;
      const RETURN_EASE = 0.02;

      let mouseX = -9999;
      let mouseY = -9999;
      let active = false;
      let rafId: number | null = null;

      const state = Array.from(blobs, () => ({
        x: 0,
        y: 0,
        paused: false,
      }));

      function tick() {
        blobs.forEach((blob, i) => {
          const s = state[i];
          const rect = blob.getBoundingClientRect();
          const cx = rect.left + rect.width / 2;
          const cy = rect.top + rect.height / 2;

          const dx = cx - mouseX;
          const dy = cy - mouseY;
          const dist = Math.sqrt(dx * dx + dy * dy);

          const inRange = active && dist < REPEL_RADIUS && dist > 1;

          if (inRange) {
            if (!s.paused) {
              blob.style.animationPlayState = 'paused, running';
              s.paused = true;
            }
            const t = 1 - dist / REPEL_RADIUS;
            const force = t * t * REPEL_FORCE;
            s.x += (dx / dist) * force;
            s.y += (dy / dist) * force;
          } else {
            s.x += (0 - s.x) * RETURN_EASE;
            s.y += (0 - s.y) * RETURN_EASE;

            if (s.paused && Math.abs(s.x) < 2 && Math.abs(s.y) < 2) {
              blob.style.animationPlayState = '';
              s.paused = false;
            }
          }

          blob.style.translate = `${s.x}px ${s.y}px`;
        });

        if (
          !active &&
          state.every(
            (s) => !s.paused && Math.abs(s.x) < 0.5 && Math.abs(s.y) < 0.5
          )
        ) {
          blobs.forEach((b) => {
            b.style.translate = '';
          });
          state.forEach((s) => {
            s.x = 0;
            s.y = 0;
          });
          rafId = null;
          return;
        }

        rafId = requestAnimationFrame(tick);
      }

      function startIfNeeded() {
        if (!rafId) {
          rafId = requestAnimationFrame(tick);
        }
      }

      document.addEventListener(
        'mousemove',
        (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;
          active = true;
          startIfNeeded();
        },
        { passive: true }
      );

      document.addEventListener('mouseleave', () => {
        active = false;
      });

      document.addEventListener(
        'touchmove',
        (e) => {
          if (e.touches.length > 0) {
            mouseX = e.touches[0].clientX;
            mouseY = e.touches[0].clientY;
            active = true;
            startIfNeeded();
          }
        },
        { passive: true }
      );

      document.addEventListener('touchend', () => {
        active = false;
      });
    })();
  </script>
</Layout>
