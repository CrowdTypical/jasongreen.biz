{
  "redirects": [
    {
      "source": "/spread-the-fund/:path(.*)",
      "has": [{ "type": "host", "value": "(?:www\\.)?jasongreen\\.biz" }],
      "destination": "https://spreadthefund.jasongreen.biz/:path*",
      "permanent": true
    },
    {
      "source": "/spread-the-fund",
      "has": [{ "type": "host", "value": "(?:www\\.)?jasongreen\\.biz" }],
      "destination": "https://spreadthefund.jasongreen.biz",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "spreadthefund.jasongreen.biz" }],
      "destination": "/spread-the-fund/:path*"
    }
  ]
}
